{
    "layer": "{{bar_layer}}",
    "position": "{{bar_position}}",
    "mode": "{{bar_mode}}",
    "exclusive": {{bar_exclusive}},
    "fixed-center": true,
    "height": {{bar_height}},
    "margin-top": {{bar_margin_top}},
    "margin-bottom": {{bar_margin_bottom}},
    "margin-left": {{bar_margin_left}},
    "margin-right": {{bar_margin_right}},
    "spacing": {{bar_spacing}},

    "modules-left": [{{bar_modules_left}}],
    "modules-center": ["clock"],
    "modules-right": [{{bar_modules_right}}],

    "custom/arch": {
        "format": "ÔŁ»_",
        "tooltip-format": "root@garuda ÔÇö you are the payload",
        "on-click": "rofi -show combi"
    },

    "hyprland/workspaces": {
        "format": "{{fmt_ws}}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "format-icons": {
            "1": "0x1",
            "2": "0x2",
            "3": "0x3",
            "4": "0x4",
            "5": "0x5",
            "6": "0x6",
            "7": "0x7",
            "8": "0x8",
            "9": "0x9",
            "10": "0xA"
        },
        "persistent-workspaces": { "*": {{bar_workspaces}} }
    },

    "hyprland/window": {
        "format": "exec Ôćĺ {}",
        "rewrite": { "^$": "[idle] ÔÇö awaiting input_" },
        "max-length": 50,
        "separate-outputs": true
    },

    "clock": {
        "format": "{{clock_fmt}}",
        "interval": {{clock_interval}},
        "format-alt": "´öá {:%Y-%m-%dT%H:%M:%S%z}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#f38ba8'><b>{}</b></span>"
            }
        }
    },

    "cpu": {
        "format": "{{fmt_cpu}}",
        "interval": 2,
        "on-click": "kitty --class htop-float -e htop"
    },

    "memory": {
        "format": "{{fmt_memory}}",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "return-type": "json",
        "format": "{}",
        "interval": 3,
        "on-click": "kitty --class nvtop-float -e nvtop"
    },

    "temperature": {
        "critical-threshold": 82,
        "format": "{{fmt_temp}}"
    },

    "pulseaudio": {
        "format": "{{fmt_audio}}",
        "format-muted": "{{fmt_audio_muted}}",
        "format-icons": { "default": ["´ÇŽ", "´Çž", "´ÇĘ"] },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },

    "network": {
        "format-wifi": "{{fmt_net_wifi}}",
        "format-ethernet": "{{fmt_net_eth}}",
        "format-disconnected": "{{fmt_net_down}}",
        "interval": 2,
        "tooltip-format": "{ifname} ÔÇö {ipaddr}/{cidr}\ngw: {gwaddr}",
        "on-click": "nm-connection-editor"
    },

    "bluetooth": {
        "format": "ˇ░é»",
        "format-off": "ˇ░é▓",
        "format-connected": "ˇ░é▒ {num_connections}",
        "on-click": "blueman-manager"
    },

    "disk": {
        "format": "{{fmt_disk}}",
        "path": "/",
        "interval": 60,
        "tooltip-format": "{used} / {total} on {path}",
        "on-click": "kitty -e ncdu /"
    },

    "custom/uptime": {
        "exec": "awk '{s=int($1); printf \"up:%dd%02dh%02dm\", s/86400, (s%86400)/3600, (s%3600)/60}' /proc/uptime",
        "format": "{}",
        "interval": 60,
        "tooltip": false
    },

    "custom/kernel": {
        "exec": "echo \"$(uname -r | cut -d- -f1)-$(uname -r | grep -oE '[a-z]+$' || echo lnx)\"; ",
        "format": "´ů╝ {}",
        "interval": 3600,
        "tooltip": false
    },

    "tray": {
        "spacing": 10,
        "icon-size": {{bar_tray_size}}
    },

    "custom/power": {
        "format": "ÔĆ╗",
        "on-click": "wlogout -b 3 -c 8 -r 8 -L 400 -R 400",
        "tooltip-format": "shutdown -h now"
    }
}
