/* {{THEME_NAME}} — waybar. Colours in colors.css. Generated by `theme`. */
@import "colors.css";

* {
    font-family: "{{font_ui}}", "Symbols Nerd Font", monospace;
    font-size: {{bar_font_size}}px;
    font-weight: {{font_weight}};
    min-height: 0;
    border-radius: {{bar_radius}}px;
    {{bar_text_transform}}
}

window#waybar {
    background: transparent;
    color: @text;
}

/* Module container groups. bar_style decides whether the GROUP carries the
   background pill (merged/flat) or each MODULE carries its own (islands). */
.modules-left, .modules-center, .modules-right {
    {{bar_group_css}}
}

/* Per-module chrome — empty for merged (group has the pill), a floating pill
   for islands, an accent underline/outline for the accent styles. */
#custom-arch, #window, #clock, #cpu, #memory, #temperature, #pulseaudio,
#network, #bluetooth, #battery, #disk, #tray, #custom-power, #custom-gpu,
#custom-uptime, #custom-kernel {
    {{bar_item_css}}
}

@keyframes blink {
    0%   { color: @green; text-shadow: 0 0 6px @green; }
    49%  { color: @green; text-shadow: 0 0 6px @green; }
    50%  { color: alpha(@green, 0.15); text-shadow: none; }
    100% { color: alpha(@green, 0.15); text-shadow: none; }
}

#custom-arch {
    color: @green;
    font-size: 18px;
    padding: 0 12px;
    {{bar_blink_css}}
}

#workspaces button {
    color: @subtext;
    padding: 0 7px;
    transition: all 0.15s ease;
}
#workspaces button.active {
    {{bar_ws_active_css}}
}
#workspaces button:hover {
    color: @green;
    background: alpha(@grid, 0.6);
    text-shadow: 0 0 6px @green;
}
#workspaces button.urgent {
    color: @bg;
    background: @red;
}

#window {
    color: @dimgrn;
    padding: 0 8px;
    font-style: italic;
}

#clock {
    color: @green;
    padding: 0 14px;
    text-shadow: 0 0 8px alpha(@green, 0.8);
}

#cpu, #memory, #temperature, #pulseaudio, #network,
#bluetooth, #battery, #tray, #custom-power, #custom-gpu {
    margin: 2px 0;
}

#cpu        { color: @green; }
#temperature { color: @green; }
#temperature.critical { color: @red; text-shadow: 0 0 8px @red; }
#memory     { color: @dimgrn; }

/* GPU zone — cyan, separated from CPU zone */
#custom-gpu {
    color: @cyan;
    border-left: 1px solid alpha(@green, 0.35);
    border-right: 1px solid alpha(@green, 0.35);
    margin: 2px 4px;
}
#custom-gpu.critical { color: @red; text-shadow: 0 0 8px @red; }
#disk       { color: @dimgrn; }
#pulseaudio { color: @cyan; }
#pulseaudio.muted { color: @subtext; }
#network    { color: @green; }
#network.disconnected { color: @red; text-shadow: 0 0 8px @red; }
#bluetooth  { color: @cyan; }
#custom-uptime {
    color: @subtext;
}
#custom-kernel {
    color: @subtext;
    font-style: italic;
}

#custom-power {
    color: @red;
    padding: 0 12px;
    font-size: 15px;
}
#custom-power:hover { text-shadow: 0 0 8px @red; }

tooltip {
    background: @bg2;
    border: 1px solid @green;
    border-radius: 0;
    box-shadow: 0 0 10px alpha(@green, 0.3);
}
tooltip label { color: @text; }

/* vertical (left/right) bar tweaks — empty for horizontal bars */
{{bar_vertical_css}}
