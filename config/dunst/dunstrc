[global]
    monitor = 0
    follow = mouse
    width = 340
    height = 120
    origin = top-right
    offset = 16x54
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 8
    separator_height = 2
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 8
    frame_width = 1
    frame_color = "#00ff41"
    gap_size = 6
    separator_color = frame
    sort = yes

    font = JetBrainsMono Nerd Font 10
    line_height = 2
    markup = full
    format = "<b>[msg] %s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    corner_radius = 0
    mouse_left_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#050805"
    foreground = "#4a7a5a"
    frame_color = "#103c22"
    timeout = 6

[urgency_normal]
    background = "#050805"
    foreground = "#b7ffcc"
    frame_color = "#00ff41"
    timeout = 8

[urgency_critical]
    background = "#050805"
    foreground = "#ff2b4a"
    frame_color = "#ff2b4a"
    format = "<b>[FATAL] %s</b>\n%b"
    timeout = 0
