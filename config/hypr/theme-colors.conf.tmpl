# {{THEME_NAME}} — generated by `theme`. Do not edit; edit the .theme palette.
# Sourced by hyprland.conf. Carries BOTH colours and STRUCTURE for the active
# theme, so switching changes shape/spacing/animation feel — not just colour.
# (Hyprland merges these blocks with the ones in hyprland.conf.)

$t_accent   = rgba({{accent}}ee)
$t_accent2  = rgba({{accent2}}ee)
$t_surface  = rgba({{surface}}aa)
$t_overlay  = rgba({{overlay}}aa)
$t_shadow   = rgba({{accent}}{{glow_alpha}})
$t_shadow_i = rgba(00000066)

general {
    gaps_in = {{gap_in}}
    gaps_out = {{gap_out}}
    border_size = {{border_width}}
    layout = {{layout}}
    col.active_border = $t_accent $t_accent2 $t_accent 45deg
    col.inactive_border = $t_overlay $t_surface 45deg
}

decoration {
    rounding = {{radius}}
    active_opacity = {{opacity_active}}
    inactive_opacity = {{opacity_inactive}}

    shadow {
        color = $t_shadow
        color_inactive = $t_shadow_i
    }

    blur {
        enabled = true
        size = {{blur_size}}
        passes = {{blur_passes}}
        vibrancy = {{blur_vibrancy}}
        vibrancy_darkness = 0.0
        # noise dithers away the visible banding rings a plain gaussian blur
        # leaves behind -> the falloff reads smooth instead of blocky
        noise = {{blur_noise}}
        contrast = {{blur_contrast}}
        brightness = {{blur_brightness}}
        # blur the popup/tooltip layers too (waybar clock, menus) so their
        # backdrop matches instead of showing a hard rectangular cut
        popups = true
        popups_ignorealpha = 0.2
    }
}

animations {
    bezier = themeCurve, {{anim_bezier}}
    animation = windows, 1, {{anim_speed}}, themeCurve, {{win_style}}
    animation = windowsIn, 1, {{anim_speed}}, themeCurve, {{win_style}}
    animation = windowsOut, 1, {{anim_speed}}, themeCurve, {{win_style}}
    animation = windowsMove, 1, {{anim_speed}}, themeCurve
    animation = fade, 1, {{anim_speed}}, themeCurve
    animation = workspaces, 1, {{anim_speed}}, themeCurve, slide
}
