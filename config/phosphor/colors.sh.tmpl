# {{THEME_NAME}} — generated by `wear`. Source this from your shell rc:
#   [ -f ~/.config/phosphor/colors.sh ] && . ~/.config/phosphor/colors.sh
# Exposes the whole palette as PHOS_* vars and themes fzf to match.

PHOS_THEME="{{THEME_NAME}}"
PHOS_ACCENT="#{{accent}}"
PHOS_ACCENT2="#{{accent2}}"
PHOS_ACCENT3="#{{accent3}}"
PHOS_BG="#{{bg}}"
PHOS_BG_ALT="#{{bg_alt}}"
PHOS_BG_DIM="#{{bg_dim}}"
PHOS_SURFACE="#{{surface}}"
PHOS_OVERLAY="#{{overlay}}"
PHOS_FG="#{{fg}}"
PHOS_FG_DIM="#{{fg_dim}}"
PHOS_RED="#{{red}}"
PHOS_GREEN="#{{green}}"
PHOS_YELLOW="#{{yellow}}"
PHOS_BLUE="#{{blue}}"
PHOS_MAGENTA="#{{magenta}}"
PHOS_CYAN="#{{cyan}}"
export PHOS_THEME PHOS_ACCENT PHOS_ACCENT2 PHOS_ACCENT3 PHOS_BG PHOS_BG_ALT \
       PHOS_BG_DIM PHOS_SURFACE PHOS_OVERLAY PHOS_FG PHOS_FG_DIM \
       PHOS_RED PHOS_GREEN PHOS_YELLOW PHOS_BLUE PHOS_MAGENTA PHOS_CYAN

# fzf — menus match the desktop
export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-} \
 --color=bg+:#{{surface}},bg:#{{bg}},spinner:#{{accent}},hl:#{{accent}} \
 --color=fg:#{{fg_dim}},header:#{{accent}},info:#{{accent2}},pointer:#{{accent}} \
 --color=marker:#{{accent3}},fg+:#{{fg}},prompt:#{{accent}},hl+:#{{accent}} \
 --color=border:#{{overlay}},gutter:#{{bg}}"
