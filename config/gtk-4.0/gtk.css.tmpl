/* {{THEME_NAME}} — generated by `theme`. Edit the .theme palette. */

/* libadwaita named colors */
@define-color accent_color #{{accent}};
@define-color accent_bg_color #{{accent}};
@define-color accent_fg_color #{{bg}};
@define-color destructive_color #{{red}};
@define-color destructive_bg_color #{{red}};
@define-color destructive_fg_color #{{bg}};
@define-color success_color #{{accent}};
@define-color success_bg_color #{{accent}};
@define-color success_fg_color #{{bg}};
@define-color warning_color #{{yellow}};
@define-color warning_bg_color #{{yellow}};
@define-color warning_fg_color #{{bg}};
@define-color error_color #{{red}};
@define-color error_bg_color #{{red}};
@define-color error_fg_color #{{bg}};

@define-color window_bg_color #{{bg_dim}};
@define-color window_fg_color #{{fg}};
@define-color view_bg_color #{{bg}};
@define-color view_fg_color #{{fg}};
@define-color headerbar_bg_color #{{bg_alt}};
@define-color headerbar_fg_color #{{fg}};
@define-color headerbar_border_color #{{surface}};
@define-color headerbar_backdrop_color #{{bg}};
@define-color headerbar_shade_color rgba(0, 0, 0, 0.36);
@define-color card_bg_color #{{bg_alt}};
@define-color card_fg_color #{{fg}};
@define-color card_shade_color rgba(0, 0, 0, 0.36);
@define-color dialog_bg_color #{{bg_dim}};
@define-color dialog_fg_color #{{fg}};
@define-color popover_bg_color #{{bg_alt}};
@define-color popover_fg_color #{{fg}};
@define-color sidebar_bg_color #{{bg_dim}};
@define-color sidebar_fg_color #{{fg}};
@define-color sidebar_backdrop_color #{{bg}};
@define-color sidebar_shade_color rgba(0, 0, 0, 0.36);
@define-color secondary_sidebar_bg_color #{{bg_dim}};
@define-color secondary_sidebar_fg_color #{{fg}};
@define-color thumbnail_bg_color #{{bg_alt}};
@define-color thumbnail_fg_color #{{fg}};
@define-color shade_color rgba(0, 0, 0, 0.36);
@define-color scrollbar_outline_color #{{surface}};

selection {
    background-color: #{{accent}};
    color: #{{on_accent}};
}
*:selected {
    background-color: #{{accent}};
    color: #{{on_accent}};
}
/* Nautilus / libadwaita grid + list + sidebar selection (was purple accent tint) */
gridview > child:selected,
gridview > child:selected:hover,
columnview listview > row:selected,
listview > row:selected,
row:selected,
.navigation-sidebar > row:selected,
.navigation-sidebar row:selected,
.view:selected,
.view > child:selected {
    background-color: #{{accent}};
    color: #{{on_accent}};
}
/* the rounded highlight tile Nautilus draws behind grid items */
gridview > child:selected > .thumbnail,
gridview.view > child:selected {
    background-color: alpha(#{{accent}}, 0.30);
    color: #{{fg}};
}

/* ---- interactive states (derived shades follow the palette) ------------- */
button.suggested-action {
    background-color: #{{accent}};
    color: #{{on_accent}};
}
button.suggested-action:hover { background-color: #{{accent_hover}}; }
button.suggested-action:active { background-color: #{{accent_active}}; }
button.destructive-action {
    background-color: #{{red}};
    color: #{{on_accent}};
}
switch:checked {
    background-color: #{{accent}};
}
switch:checked > slider { background-color: #{{on_accent}}; }
checkbutton check:checked,
checkbutton radio:checked,
radiobutton radio:checked {
    background-color: #{{accent}};
    border-color: #{{accent}};
    color: #{{on_accent}};
}
scale > trough > highlight {
    background-color: #{{accent}};
}
scale > trough > slider {
    background-color: #{{fg}};
}
progressbar > trough > progress {
    background-color: #{{accent}};
}
spinbutton:focus-within,
entry:focus,
entry:focus-within {
    outline-color: #{{accent}};
    border-color: #{{accent}};
}
link, link:visited > label { color: #{{accent2}}; }

/* tabs / notebooks */
notebook > header > tabs > tab:checked {
    color: #{{accent}};
    box-shadow: inset 0 -2px #{{accent}};
}
tabbar tab:selected {
    color: #{{accent}};
    box-shadow: inset 0 -2px #{{accent}};
}

/* menus & popovers */
popover.menu modelbutton:hover,
menubutton popover.menu > contents modelbutton:hover {
    background-color: alpha(#{{accent}}, 0.22);
}

/* hover rows follow the palette (not the base theme grey) */
listview > row:hover:not(:selected),
row.activatable:hover:not(:selected) {
    background-color: #{{bg_hover}};
}

tooltip {
    background-color: #{{bg_dim}};
    color: #{{fg}};
    border: 1px solid #{{accent}};
    border-radius: {{radius}}px;
}

/* text selection inside editors/terminals */
textview text selection,
entry > text selection,
label selection {
    background-color: alpha(#{{accent}}, 0.45);
    color: #{{fg}};
}
