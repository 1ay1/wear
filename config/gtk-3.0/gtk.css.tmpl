/* {{THEME_NAME}} — generated by `theme`. Do not edit; edit the .theme palette. */

/* core named colors */
@define-color theme_bg_color #{{bg_dim}};
@define-color theme_base_color #{{bg}};
@define-color theme_fg_color #{{fg}};
@define-color theme_text_color #{{fg}};
@define-color theme_selected_bg_color #{{accent}};
@define-color theme_selected_fg_color #{{bg}};
@define-color theme_unfocused_bg_color #{{bg}};
@define-color theme_unfocused_base_color #{{bg}};
@define-color theme_unfocused_fg_color #{{fg_dim}};
@define-color theme_unfocused_text_color #{{fg_dim}};
@define-color insensitive_bg_color #{{bg_dim}};
@define-color insensitive_fg_color #{{fg_dim}};
@define-color insensitive_base_color #{{bg}};
@define-color borders #{{surface}};
@define-color unfocused_borders #{{surface}};

/* accents + semantics */
@define-color accent_color #{{accent}};
@define-color accent_bg_color #{{accent}};
@define-color accent_fg_color #{{bg}};
@define-color warning_color #{{yellow}};
@define-color error_color #{{red}};
@define-color success_color #{{accent}};
@define-color destructive_color #{{red}};
@define-color link_color #{{accent2}};
@define-color visited_link_color #{{fg_dim}};

/* headerbar / sidebar / popover */
@define-color headerbar_bg_color #{{bg_alt}};
@define-color headerbar_fg_color #{{fg}};
@define-color headerbar_border_color #{{surface}};
@define-color headerbar_backdrop_color #{{bg}};
@define-color sidebar_bg_color #{{bg_dim}};
@define-color sidebar_fg_color #{{fg}};
@define-color sidebar_backdrop_color #{{bg}};
@define-color popover_bg_color #{{bg_alt}};
@define-color popover_fg_color #{{fg}};
@define-color dialog_bg_color #{{bg_dim}};
@define-color dialog_fg_color #{{fg}};
@define-color card_bg_color #{{bg_alt}};
@define-color card_fg_color #{{fg}};
@define-color view_bg_color #{{bg}};
@define-color view_fg_color #{{fg}};
@define-color window_bg_color #{{bg_dim}};
@define-color window_fg_color #{{fg}};

selection {
    background-color: #{{accent}};
    color: #{{bg}};
}
*:selected {
    background-color: #{{accent}};
    color: #{{bg}};
}

/* hard overrides where themes ignore named colors */
headerbar, .titlebar {
    background: #{{bg_alt}};
    color: #{{fg}};
    border-bottom: 1px solid #{{surface}};
    box-shadow: none;
}
headerbar:backdrop, .titlebar:backdrop {
    background: #{{bg}};
    color: #{{fg_dim}};
}
window, dialog, .background {
    background-color: #{{bg_dim}};
    color: #{{fg}};
}
/* Toolbars, menubars, action bars, statusbars — kill the accent leak */
toolbar, .toolbar, .inline-toolbar, .primary-toolbar,
menubar, .menubar, actionbar, .action-bar, .location-bar,
searchbar, .search-bar, .statusbar, statusbar,
box.toolbar, headerbar .toolbar, paned > separator,
.background.csd, .titlebar .toolbar {
    background-color: #{{bg_dim}};
    background-image: none;
    color: #{{fg}};
    border-color: #{{surface}};
    box-shadow: none;
}
menubar > menuitem {
    color: #{{fg}};
    background-color: transparent;
}
menubar > menuitem:hover, menubar > menuitem:active {
    background-color: #{{surface}};
    color: #{{accent}};
}
textview, textview text, treeview.view, list, listview, iconview {
    background-color: #{{bg}};
    color: #{{fg}};
}
/* Thunar / Nautilus content view area (the icon-view pane) */
scrolledwindow, scrolledwindow > viewport, .view, iconview.view,
.standard-view, .standard-view .view, .thunar-standard-view,
treeview.view:not(:selected), .content-view, GtkIconView {
    background-color: #{{bg}};
    color: #{{fg}};
}
iconview:selected, iconview .cell:selected,
.view:selected, .standard-view .view:selected {
    background-color: #{{surface}};
    color: #{{accent}};
}
entry {
    background-color: #{{bg}};
    color: #{{fg}};
    border-color: #{{surface}};
    caret-color: #{{accent}};
}
entry:focus {
    border-color: #{{accent}};
}
button {
    background-image: none;
    background-color: #{{bg_alt}};
    color: #{{fg}};
    border-color: #{{surface}};
}
button:hover {
    background-color: #{{surface}};
    border-color: #{{accent}};
}
button:checked, button:active {
    background-color: #{{accent}};
    color: #{{bg}};
}
menu, .menu, popover, popover.background {
    background-color: #{{bg_alt}};
    color: #{{fg}};
    border: 1px solid #{{surface}};
}
menuitem:hover, modelbutton:hover, row:selected, row.activatable:hover {
    background-color: #{{surface}};
    color: #{{accent}};
}
notebook > header {
    background-color: #{{bg_dim}};
}
notebook > header > tabs > tab {
    color: #{{fg_dim}};
}
notebook > header > tabs > tab:checked {
    color: #{{accent}};
    box-shadow: inset 0 -2px #{{accent}};
}
scrollbar slider {
    background-color: #{{surface}};
    border-radius: 0;
}
scrollbar slider:hover {
    background-color: #{{accent}};
}
tooltip, tooltip.background {
    background-color: #{{bg_dim}};
    color: #{{fg}};
    border: 1px solid #{{accent}};
    border-radius: 0;
}
progressbar > trough > progress {
    background-color: #{{accent}};
}
scale > trough > highlight {
    background-color: #{{accent}};
}
switch:checked {
    background-color: #{{accent}};
}
switch:checked slider {
    background-color: #{{bg}};
}
check:checked, radio:checked {
    background-color: #{{accent}};
    color: #{{bg}};
}
