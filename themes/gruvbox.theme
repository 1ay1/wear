bg_dim="1d2021"
surface="504945"
overlay="3c3836"

fg="ebdbb2"
fg_dim="a89984"
fg_faint="7c6f64"

accent="fabd2f"
accent2="8ec07c"
accent3="fe8019"

red="fb4934"
green="b8bb26"
yellow="fabd2f"
blue="83a598"
magenta="d3869b"
