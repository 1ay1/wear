#!/usr/bin/env bash
# ============================================================================
#  wear — one-command switcher for the whole Phosphor desktop.
#  Switches EVERYTHING: Hyprland borders/shadows, hyprlock, waybar, rofi, dunst,
#  kitty, GTK3/4, Qt5/6, KDE colour scheme, satty, wlogout, and the wallpaper.
#
#  Usage:
#    wear                  # interactive picker (rofi if in a session, else fzf/menu)
#    wear <name>           # wear <name> (e.g. tokyo-night, gruvbox, phosphor)
#    wear list             # list available themes
#    wear current          # print the active theme
#    wear reload           # re-apply the current theme (after editing a .theme)
#
#  Themes live in  $REPO/themes/*.theme  and are rendered into ~/.config via
#  the *.tmpl templates under $REPO/config (and $REPO/kde).
# ============================================================================
set -euo pipefail

# --- locate the repo (this script lives in $REPO/home/local-bin/) -----------
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
# Prefer an explicit env override, else derive from the script location, else
# fall back to a couple of common clone paths.
REPO="${PHOSPHOR_REPO:-}"
if [ -z "$REPO" ]; then
  cand="$(cd "$(dirname "$SELF")/../.." 2>/dev/null && pwd || true)"
  if [ -n "$cand" ] && [ -d "$cand/themes" ]; then REPO="$cand"; fi
fi
for p in "$HOME/phosphor-hypr" "$HOME/.local/share/phosphor-hypr" "$HOME/dotfiles/phosphor-hypr"; do
  [ -n "$REPO" ] && break
  [ -d "$p/themes" ] && REPO="$p"
done
if [ -z "${REPO:-}" ] || [ ! -d "$REPO/themes" ]; then
  echo "theme: could not find the phosphor-hypr repo (set PHOSPHOR_REPO=/path)" >&2
  exit 1
fi

CFG="$HOME/.config"
THEMES_DIR="$REPO/themes"
STATE="$CFG/phosphor/theme"       # remembers the active base theme name
OVERRIDES="$CFG/phosphor/overrides.conf"  # per-key live tweaks on top of base

GREEN='\033[0;32m'; BOLD='\033[1m'; DIM='\033[2m'; RED='\033[0;31m'; NC='\033[0m'
say()  { echo -e "${GREEN}${BOLD}::${NC} $*"; }
info() { echo -e "   ${DIM}$*${NC}"; }
warn() { echo -e "${RED}!!${NC} $*" >&2; }

# --- helpers ----------------------------------------------------------------
list_themes() {
  for f in "$THEMES_DIR"/*.theme; do
    [ -e "$f" ] || continue
    basename "$f" .theme
  done | sort
}

pretty_name() {  # $1 = theme slug -> its display name
  ( set -a; . "$THEMES_DIR/$1.theme"; echo "${name:-$1}" )
}

current_theme() { [ -f "$STATE" ] && cat "$STATE" || echo "phosphor"; }

# hex(RRGGBB) -> "R,G,B" decimal (for KDE .colors {{key|rgb}} tokens)
hex_to_rgb() {
  local h="${1#\#}"
  printf '%d,%d,%d' "0x${h:0:2}" "0x${h:2:2}" "0x${h:4:2}"
}

# --- discover available options on THIS machine (for dynamic pickers) -------
list_options() { # $1 = kind
  case "$1" in
    gtk_theme)
      echo "auto"   # neutral base (adw-gtk3) recoloured by the generated gtk.css
      { ls /usr/share/themes "$HOME/.themes" "$HOME/.local/share/themes" 2>/dev/null; } \
        | grep -vE 'hdpi$|xhdpi$' | sort -u ;;
    icon_theme)
      local d t
      for d in /usr/share/icons "$HOME/.icons" "$HOME/.local/share/icons"; do
        [ -d "$d" ] || continue
        for t in "$d"/*/; do
          [ -f "$t/index.theme" ] && [ ! -d "$t/cursors" ] && basename "$t"
        done
      done | sort -u ;;
    cursor_theme)
      local d t
      for d in /usr/share/icons "$HOME/.icons" "$HOME/.local/share/icons"; do
        [ -d "$d" ] || continue
        for t in "$d"/*/; do [ -d "$t/cursors" ] && basename "$t"; done
      done | sort -u ;;
    kvantum_theme)
      { ls /usr/share/Kvantum "$HOME/.config/Kvantum" 2>/dev/null; } \
        | grep -v '\.kvconfig$' | sort -u ;;
    qt_style)
      printf '%s\n' Fusion Windows kvantum kvantum-dark ;;
    wallpaper_shader)
      ls "$CFG/neowall/shaders/" 2>/dev/null | sed 's/\.glsl$//' | sort -u ;;
    font)
      command -v fc-list >/dev/null 2>&1 && fc-list : family | sed 's/,.*//' | sort -u ;;
    *) return 1 ;;
  esac
}

# --- render a single template ($1=src.tmpl  $2=dest) using the loaded palette
render() {
  local src="$1" dest="$2"
  [ -f "$src" ] || { warn "missing template: $src"; return 0; }
  mkdir -p "$(dirname "$dest")"
  # Build a sed program: {{KEY}} -> value, {{KEY|rgb}} -> R,G,B (hex keys only),
  # {{THEME_NAME}} -> display name.
  local prog="" k v
  for k in "${!PAL[@]}"; do
    v="${PAL[$k]}"
    # only colour keys (exactly 6 hex digits) get an {{KEY|rgb}} decimal form
    if [[ "$v" =~ ^[0-9a-fA-F]{6}$ ]]; then
      prog+="s|{{${k}\\|rgb}}|$(hex_to_rgb "$v")|g;"
    fi
    prog+="s|{{${k}}}|${v}|g;"
  done
  prog+="s|{{THEME_NAME}}|${THEME_DISPLAY}|g;"
  sed -e "$prog" "$src" > "$dest"
}

# --- load a palette file into the PAL associative array ---------------------
load_palette() {
  local slug="$1" file="$THEMES_DIR/$1.theme"
  [ -f "$file" ] || { warn "no such theme: $slug"; echo; echo "Available:"; list_themes; exit 1; }
  declare -gA PAL=()
  # shellcheck disable=SC1090
  ( set -a; . "$file"; )   # syntax-check
  # source into current shell and copy the flat vars we care about
  set -a; . "$file"; set +a
  local keys=(bg bg_alt bg_dim surface overlay fg fg_dim fg_faint
    accent accent2 accent3 red green yellow blue magenta cyan
    br_black br_red br_green br_yellow br_blue br_magenta br_cyan br_white
    on_accent
    radius border_width gap_in gap_out layout
    opacity_active opacity_inactive blur_size blur_passes blur_vibrancy glow
    anim_speed anim_bezier anim_style
    bar_position bar_height bar_margin bar_spacing bar_radius
    font_ui font_mono font_size_ui font_size_term font_weight
    term_opacity term_padding cursor_size qt_style kvantum_theme)
  local k
  for k in "${keys[@]}"; do PAL[$k]="${!k}"; done

  # --- overlay live per-key tweaks from OVERRIDES (the tweaker writes these) ---
  # Each line is  key=value  (unquoted). Colour keys are 6 hex digits (no #).
  # These win over the base theme so users can nudge any single property live.
  if [ -f "$OVERRIDES" ]; then
    local oline okey oval
    while IFS= read -r oline || [ -n "$oline" ]; do
      case "$oline" in ''|\#*) continue ;; esac
      okey="${oline%%=*}"; oval="${oline#*=}"
      okey="${okey// /}"                       # trim spaces around the key
      oval="${oval%\"}"; oval="${oval#\"}"      # strip optional wrapping quotes
      [ -z "$okey" ] && continue
      PAL[$okey]="$oval"
      # engine/meta keys also flow through the shell vars used below
      case "$okey" in
        name)             name="$oval" ;;
        mode)             mode="$oval" ;;
        gtk_theme)        gtk_theme="$oval" ;;
        icon_theme)       icon_theme="$oval" ;;
        cursor_theme)     cursor_theme="$oval" ;;
        wallpaper_shader) wallpaper_shader="$oval" ;;
      esac
    done < "$OVERRIDES"
  fi

  # sensible fallbacks for older palette files that lack structure keys
  : "${PAL[radius]:=8}";           : "${PAL[border_width]:=2}"
  : "${PAL[gap_in]:=6}";           : "${PAL[gap_out]:=14}"
  : "${PAL[layout]:=dwindle}"
  : "${PAL[opacity_active]:=1.0}"; : "${PAL[opacity_inactive]:=0.94}"
  : "${PAL[blur_size]:=8}";        : "${PAL[blur_passes]:=3}"
  : "${PAL[blur_vibrancy]:=0.25}"; : "${PAL[glow]:=0.25}"
  : "${PAL[anim_speed]:=6}";       : "${PAL[anim_bezier]:=0.05, 0.9, 0.1, 1.05}"
  : "${PAL[anim_style]:=slide}"
  : "${PAL[bar_position]:=top}";   : "${PAL[bar_height]:=36}"
  : "${PAL[bar_margin]:=8}";       : "${PAL[bar_spacing]:=6}"; : "${PAL[bar_radius]:=0}"
  : "${PAL[font_ui]:=JetBrainsMono Nerd Font}"
  : "${PAL[font_mono]:=JetBrainsMono Nerd Font}"
  : "${PAL[font_size_ui]:=13}";    : "${PAL[font_size_term]:=11.0}"
  : "${PAL[font_weight]:=bold}"
  : "${PAL[term_opacity]:=1.0}";   : "${PAL[term_padding]:=0}"
  : "${PAL[cursor_size]:=24}";     : "${PAL[qt_style]:=Fusion}"
  : "${PAL[kvantum_theme]:=Sweet}"

  # derived: glow (0..1) -> 2-digit hex alpha for shadow, and a px radius
  local g="${PAL[glow]}"
  PAL[glow_alpha]="$(awk -v g="$g" 'BEGIN{printf "%02x", int(g*255)}')"
  PAL[glow_px]="$(awk -v g="$g" 'BEGIN{printf "%d", int(g*24)+2}')"

  # derived shades — computed mixes so widget hover/pressed states follow the
  # palette automatically (no extra keys for the user to define).
  #   mix(a,b,f) = a*(1-f) + b*f   per channel
  _mix() { awk -v a="$1" -v b="$2" -v f="$3" 'BEGIN{
    ar=strtonum("0x" substr(a,1,2)); ag=strtonum("0x" substr(a,3,2)); ab=strtonum("0x" substr(a,5,2))
    br=strtonum("0x" substr(b,1,2)); bg=strtonum("0x" substr(b,3,2)); bb=strtonum("0x" substr(b,5,2))
    printf "%02x%02x%02x", ar+(br-ar)*f, ag+(bg-ag)*f, ab+(bb-ab)*f }'
  }
  PAL[accent_hover]="$(_mix "${PAL[accent]}" "ffffff" 0.15)"   # accent, lightened
  PAL[accent_active]="$(_mix "${PAL[accent]}" "000000" 0.20)"  # accent, pressed
  PAL[accent_dim]="$(_mix "${PAL[accent]}" "${PAL[bg]}" 0.60)" # washed accent
  PAL[bg_hover]="$(_mix "${PAL[bg]}" "${PAL[fg]}" 0.07)"       # subtle row hover
  PAL[surface_hover]="$(_mix "${PAL[surface]}" "${PAL[fg]}" 0.10)"
  PAL[border_dim]="$(_mix "${PAL[overlay]}" "${PAL[bg]}" 0.40)"

  # window animations only accept slide/popin — map fade to a safe default
  case "${PAL[anim_style]}" in
    fade|"") PAL[win_style]="slide" ;;
    *)       PAL[win_style]="${PAL[anim_style]}" ;;
  esac
  THEME_DISPLAY="${name:-$slug}"
  THEME_MODE="${mode:-dark}"
  GTK_THEME_NAME="${gtk_theme:-auto}"
  # "auto" = neutral base theme fully recoloured by our generated gtk.css.
  # adw-gtk3 is designed for exactly this; fall back to stock Adwaita.
  if [ "$GTK_THEME_NAME" = "auto" ] || [ -z "$GTK_THEME_NAME" ]; then
    local dark_sfx=""; [ "$THEME_MODE" != "light" ] && dark_sfx="-dark"
    if [ -d "/usr/share/themes/adw-gtk3$dark_sfx" ]; then
      GTK_THEME_NAME="adw-gtk3$dark_sfx"
    elif [ -n "$dark_sfx" ]; then
      GTK_THEME_NAME="Adwaita-dark"
    else
      GTK_THEME_NAME="Adwaita"
    fi
  fi
  ICON_THEME="${icon_theme:-Papirus-Dark}"
  CURSOR_THEME="${cursor_theme:-Bibata-Modern-Amber}"
  WALL_SHADER="${wallpaper_shader:-}"
  GTK_THEME_RAW="${gtk_theme:-auto}"   # what the user actually chose (may be "auto")
  # engine keys mirrored into PAL so `values`/the GUI can read & tweak them
  PAL[mode]="$THEME_MODE"
  PAL[gtk_theme]="$GTK_THEME_RAW"
  PAL[icon_theme]="$ICON_THEME"
  PAL[cursor_theme]="$CURSOR_THEME"
  PAL[wallpaper_shader]="$WALL_SHADER"
}

# --- apply everything -------------------------------------------------------
apply_theme() {
  local slug="$1" keep_overrides="${2:-}"
  # Switching to a NEW base theme wipes live tweaks unless caller says keep.
  if [ "$keep_overrides" != "keep" ] && [ "$slug" != "$(current_theme)" ]; then
    : > "$OVERRIDES" 2>/dev/null || true
  fi
  load_palette "$slug"
  say "Switching to ${BOLD}${THEME_DISPLAY}${NC}"

  # 1. render every templated config -> live ~/.config
  render "$REPO/config/kitty/current-theme.conf.tmpl"     "$CFG/kitty/current-theme.conf"
  render "$REPO/config/dunst/dunstrc.tmpl"                "$CFG/dunst/dunstrc"
  render "$REPO/config/rofi/colors.rasi.tmpl"             "$CFG/rofi/colors.rasi"
  render "$REPO/config/rofi/theme-picker.rasi.tmpl"       "$CFG/rofi/theme-picker.rasi"
  render "$REPO/config/waybar/colors.css.tmpl"            "$CFG/waybar/colors.css"
  render "$REPO/config/waybar/style.css.tmpl"             "$CFG/waybar/style.css"
  render "$REPO/config/waybar/config.jsonc.tmpl"          "$CFG/waybar/config.jsonc"
  render "$REPO/config/hypr/theme-colors.conf.tmpl"       "$CFG/hypr/theme-colors.conf"
  render "$REPO/config/hypr/hyprlock.conf.tmpl"           "$CFG/hypr/hyprlock.conf"
  render "$REPO/config/kitty/theme-structure.conf.tmpl"   "$CFG/kitty/theme-structure.conf"
  render "$REPO/config/gtk-3.0/gtk.css.tmpl"              "$CFG/gtk-3.0/gtk.css"
  render "$REPO/config/gtk-4.0/gtk.css.tmpl"              "$CFG/gtk-4.0/gtk.css"
  render "$REPO/config/qt5ct/colors/theme.conf.tmpl"      "$CFG/qt5ct/colors/theme.conf"
  render "$REPO/config/qt6ct/colors/theme.conf.tmpl"      "$CFG/qt6ct/colors/theme.conf"
  render "$REPO/config/satty/config.toml.tmpl"            "$CFG/satty/config.toml"
  render "$REPO/config/wlogout/style.css.tmpl"            "$CFG/wlogout/style.css"
  render "$REPO/kde/color-schemes/theme.colors.tmpl"      "$HOME/.local/share/color-schemes/Phosphor.colors"
  info "rendered config templates"

  # point qt5ct/qt6ct at the freshly rendered color scheme + set widget style/font
  for qc in "$CFG/qt5ct/qt5ct.conf" "$CFG/qt6ct/qt6ct.conf"; do
    [ -f "$qc" ] || continue
    sed -i -E 's|^(color_scheme_path=).*|\1'"$CFG"'/'"$(basename "$(dirname "$qc")")"'/colors/theme.conf|' "$qc" 2>/dev/null || true
    sed -i -E "s|^(style=).*|\\1${PAL[qt_style]}|" "$qc" 2>/dev/null || true
  done

  # rewrite GTK settings.ini: theme engine, font, cursor size (icon/cursor names too)
  for gs in "$CFG/gtk-3.0/settings.ini" "$CFG/gtk-4.0/settings.ini"; do
    [ -f "$gs" ] || continue
    [ -n "$GTK_THEME_NAME" ] && sed -i -E "s|^(gtk-theme-name=).*|\\1${GTK_THEME_NAME}|" "$gs" 2>/dev/null || true
    sed -i -E "s|^(gtk-icon-theme-name=).*|\\1${ICON_THEME}|" "$gs" 2>/dev/null || true
    sed -i -E "s|^(gtk-cursor-theme-name=).*|\\1${CURSOR_THEME}|" "$gs" 2>/dev/null || true
    sed -i -E "s|^(gtk-cursor-theme-size=).*|\\1${PAL[cursor_size]}|" "$gs" 2>/dev/null || true
    sed -i -E "s|^(gtk-font-name=).*|\\1${PAL[font_ui]} ${PAL[font_size_ui]%.*}|" "$gs" 2>/dev/null || true
  done

  # Kvantum theme
  if [ -f "$CFG/Kvantum/kvantum.kvconfig" ]; then
    sed -i -E "s|^(theme=).*|\\1${PAL[kvantum_theme]}|" "$CFG/Kvantum/kvantum.kvconfig" 2>/dev/null || true
  fi

  # cursor size for Hyprland/XCURSOR at runtime
  command -v hyprctl >/dev/null 2>&1 && \
    hyprctl setcursor "$CURSOR_THEME" "${PAL[cursor_size]}" >/dev/null 2>&1 || true

  # 2. GTK / icon / cursor / dark-light via gsettings
  if command -v gsettings >/dev/null 2>&1; then
    local S=org.gnome.desktop.interface
    [ -n "$GTK_THEME_NAME" ] && gsettings set $S gtk-theme "$GTK_THEME_NAME" 2>/dev/null || true
    gsettings set $S icon-theme   "$ICON_THEME"   2>/dev/null || true
    gsettings set $S cursor-theme "$CURSOR_THEME" 2>/dev/null || true
    if [ "$THEME_MODE" = "light" ]; then
      gsettings set $S color-scheme 'prefer-light' 2>/dev/null || true
    else
      gsettings set $S color-scheme 'prefer-dark' 2>/dev/null || true
    fi
  fi
  # also flip GTK settings.ini dark hint
  for gs in "$CFG/gtk-3.0/settings.ini" "$CFG/gtk-4.0/settings.ini"; do
    [ -f "$gs" ] || continue
    if [ "$THEME_MODE" = "light" ]; then
      sed -i 's/gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=0/' "$gs" 2>/dev/null || true
    else
      sed -i 's/gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=1/' "$gs" 2>/dev/null || true
    fi
  done

  # 3. KDE colour scheme (for Dolphin/Kate under Plasma integration)
  if command -v kwriteconfig6 >/dev/null 2>&1; then
    kwriteconfig6 --file kdeglobals --group General --key ColorScheme "$THEME_DISPLAY" 2>/dev/null || true
  elif command -v kwriteconfig5 >/dev/null 2>&1; then
    kwriteconfig5 --file kdeglobals --group General --key ColorScheme "$THEME_DISPLAY" 2>/dev/null || true
  fi

  # 4. wallpaper shader (neowall)
  if [ -n "$WALL_SHADER" ] && command -v neowall >/dev/null 2>&1; then
    local shader="$CFG/neowall/shaders/$WALL_SHADER.glsl"
    [ -f "$shader" ] || shader="$CFG/neowall/shaders/$WALL_SHADER"
    if [ -e "$shader" ]; then
      ( neowall load "$shader" >/dev/null 2>&1 || neowall shader "$shader" >/dev/null 2>&1 || \
        neowall "$shader" >/dev/null 2>&1 ) &
      info "wallpaper -> $WALL_SHADER"
    fi
  fi

  # 5. reload live apps
  reload_apps

  # 6. persist active theme
  mkdir -p "$(dirname "$STATE")"
  echo "$slug" > "$STATE"

  say "Done. Now running ${BOLD}${THEME_DISPLAY}${NC} 🎨"
  info "kitty: reload with Ctrl+Shift+F5 (or new window). Qt6 apps: relaunch."
}

reload_apps() {
  # kitty — live reload all instances via SIGUSR1
  pkill -SIGUSR1 -x kitty 2>/dev/null || true
  # hyprland (border/shadow colours) + hyprlock config
  command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null 2>&1 || true
  # dunst
  if command -v dunst >/dev/null 2>&1; then
    pkill -x dunst 2>/dev/null || true
    ( setsid dunst >/dev/null 2>&1 & ) || true
  fi
  # waybar
  if command -v waybar >/dev/null 2>&1; then
    pkill -x waybar 2>/dev/null || true
    ( setsid waybar >/dev/null 2>&1 & ) || true
  fi
  # gtk apps: bump the theme to force a reread (xsettings)
  command -v gsettings >/dev/null 2>&1 && \
    gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME" 2>/dev/null || true
  info "reloaded kitty · hyprland · dunst · waybar"
}

# ============================================================================
#  APPEARANCE TWEAKER  —  live per-property editing on top of the base theme
# ============================================================================

# Persist a single override then re-apply the current base with tweaks kept.
set_override() {   # $1=key  $2=value
  local key="$1" val="$2"
  mkdir -p "$(dirname "$OVERRIDES")"; touch "$OVERRIDES"
  # drop any existing line for this key, then append the new one
  grep -vE "^[[:space:]]*${key}=" "$OVERRIDES" > "$OVERRIDES.tmp" 2>/dev/null || true
  mv "$OVERRIDES.tmp" "$OVERRIDES"
  printf '%s=%s\n' "$key" "$val" >> "$OVERRIDES"
}

unset_override() { # $1=key
  [ -f "$OVERRIDES" ] || return 0
  grep -vE "^[[:space:]]*${1}=" "$OVERRIDES" > "$OVERRIDES.tmp" 2>/dev/null || true
  mv "$OVERRIDES.tmp" "$OVERRIDES"
}

# current effective value of a key (override wins, else base theme, else "")
eff_value() {   # $1=key
  load_palette "$(current_theme)" >/dev/null 2>&1
  printf '%s' "${PAL[$1]:-}"
}

# Snapshot the *effective* palette (base + overrides) into a new .theme file.
save_theme() {  # $1=new slug
  local slug="$1"
  [ -z "$slug" ] && { warn "usage: wear save <name>"; return 1; }
  slug="$(echo "$slug" | tr ' ' '-' | tr -cd '[:alnum:]._-')"
  local out="$THEMES_DIR/$slug.theme"
  load_palette "$(current_theme)" >/dev/null 2>&1
  {
    echo "# $slug — saved by \`wear save\` on $(date '+%Y-%m-%d %H:%M')"
    echo "name=\"${PAL[name]:-$slug}\""
    echo "mode=\"${THEME_MODE}\""
    local k
    for k in bg bg_alt bg_dim surface overlay fg fg_dim fg_faint \
             accent accent2 accent3 red green yellow blue magenta cyan \
             br_black br_red br_green br_yellow br_blue br_magenta br_cyan br_white \
             on_accent radius border_width gap_in gap_out layout \
             opacity_active opacity_inactive blur_size blur_passes blur_vibrancy glow \
             anim_speed anim_bezier anim_style bar_position bar_height bar_margin \
             bar_spacing bar_radius font_ui font_mono font_size_ui font_size_term \
             font_weight term_opacity term_padding cursor_size qt_style kvantum_theme; do
      printf '%s="%s"\n' "$k" "${PAL[$k]:-}"
    done
    echo "gtk_theme=\"${GTK_THEME_RAW}\""
    echo "icon_theme=\"${ICON_THEME}\""
    echo "cursor_theme=\"${CURSOR_THEME}\""
    echo "wallpaper_shader=\"${WALL_SHADER}\""
  } > "$out"
  say "saved theme -> ${BOLD}$slug${NC}  ($out)"
  echo "$slug" > "$STATE"; : > "$OVERRIDES"
  info "now the active base theme (overrides cleared)"
}

# Editable-property schema.  Format per line:
#   key|Label|type|spec
# type: color | int:min:max:step | float:min:max:step | choice | font | pick:<kind>
# spec: for choice, a comma list; for pick, ignored (options discovered on
# disk via list_options); otherwise a hint string.
tweak_schema() {
  cat <<'SCHEMA'
## Colours
accent|Accent|color|primary highlight
accent2|Accent 2|color|secondary
accent3|Accent 3|color|tertiary
on_accent|On accent|color|text on accent fills
bg|Background|color|main bg
bg_alt|Background alt|color|panels/bar bg
bg_dim|Background dim|color|darkest wells
surface|Surface|color|cards/popups
overlay|Overlay|color|borders/inactive
fg|Foreground|color|main text
fg_dim|Foreground dim|color|secondary text
fg_faint|Foreground faint|color|disabled text
## Terminal palette
red|Red|color|errors
green|Green|color|success
yellow|Yellow|color|warnings
blue|Blue|color|
magenta|Magenta|color|
cyan|Cyan|color|
br_black|Bright black|color|comments/grey
br_red|Bright red|color|
br_green|Bright green|color|
br_yellow|Bright yellow|color|
br_blue|Bright blue|color|
br_magenta|Bright magenta|color|
br_cyan|Bright cyan|color|
br_white|Bright white|color|
## Shape
radius|Corner radius|int:0:30:2|window rounding px
border_width|Border width|int:0:8:1|px
gap_in|Inner gap|int:0:30:2|px between windows
gap_out|Outer gap|int:0:40:2|px to screen edge
layout|Tiling layout|choice|dwindle,master
