# ============================================================================
#  GENERATORS + HISTORY
# ============================================================================
HISTORY_DIR="$CFG/phosphor/history"

# snapshot current state (base + overrides) for undo
snapshot() {
  mkdir -p "$HISTORY_DIR"
  local ts; ts="$(date +%s%N)"
  { echo "base=$(current_theme)"; [ -f "$OVERRIDES" ] && sed 's/^/ov:/' "$OVERRIDES"; } \
    > "$HISTORY_DIR/$ts"
  # keep last 30
  ls -1t "$HISTORY_DIR" 2>/dev/null | tail -n +31 | while read -r f; do rm -f "$HISTORY_DIR/$f"; done
}

undo() {
  local last; last="$(ls -1t "$HISTORY_DIR" 2>/dev/null | head -1)"
  [ -z "$last" ] && { warn "nothing to undo"; return 1; }
  local f="$HISTORY_DIR/$last" base
  base="$(grep '^base=' "$f" | cut -d= -f2-)"
  grep '^ov:' "$f" | sed 's/^ov://' > "$OVERRIDES" || : > "$OVERRIDES"
  rm -f "$f"
  [ -f "$THEMES_DIR/$base.theme" ] && echo "$base" > "$STATE"
  apply_theme "$(current_theme)" keep
  say "undone → $(pretty_name "$(current_theme)")"
}

# wear from-color <hex> [name] — full theme from ONE colour
from_color() {
  local hex; hex="$(_norm_color "${1:-}")" || { warn "usage: wear from-color <colour> [name] [--light]  (hex, #abc, or a name like 'teal')"; return 1; }
  local nm="${2:-}" gmode=dark
  case "${2:-}${3:-}" in *--light*) gmode=light ;; esac
  case "$nm" in --light|"") nm="c-$hex" ;; esac
  local slug; slug="$(echo "$nm" | tr ' ' '-' | tr -cd '[:alnum:]._-' | tr 'A-Z' 'a-z')"
  say "generating ${BOLD}$slug${NC} from #$hex ($gmode)"
  gen_palette "$hex" "$gmode"
  snapshot
  write_generated_theme "$slug" "$nm" "$gmode" >/dev/null
  : > "$OVERRIDES"; echo "$slug" > "$STATE"
  apply_theme "$slug" keep
}

# wear from <image> [name] — theme from a wallpaper/photo
from_image() {
  local img="${1:-}"
  [ -f "$img" ] || { warn "usage: wear from <image> [name] [--light]"; return 1; }
  command -v magick >/dev/null 2>&1 || command -v convert >/dev/null 2>&1 \
    || { warn "needs imagemagick (magick/convert)"; return 1; }
  local IM=magick; command -v magick >/dev/null 2>&1 || IM=convert
  say "extracting palette from ${BOLD}$(basename "$img")${NC}…"
  # dominant vivid colour: quantize to 8, pick the most saturated non-grey
  local hist seed
  hist="$($IM "$img" -resize 200x200 -colors 8 -depth 8 -format '%c' histogram:info:- 2>/dev/null \
          | grep -oE '#[0-9A-Fa-f]{6}' | tr -d '#')"
  [ -z "$hist" ] && { warn "could not extract colours"; return 1; }
  seed="$(echo "$hist" | while read -r c; do
      read -r H S L <<<"$(_hsl "$c")"
      # score = saturation, penalised at extreme lightness
      awk -v c="$c" -v s="$S" -v l="$L" 'BEGIN{ p=(l<0.15||l>0.85)?0.3:1; printf "%.4f %s\n", s*p, c }'
    done | sort -rn | head -1 | awk '{print $2}')"
  [ -z "$seed" ] && seed="$(echo "$hist" | head -1)"
  info "seed colour: #$seed"
  local nm="${2:-}" gmode=dark
  case "${2:-}${3:-}" in *--light*) gmode=light ;; esac
  case "$nm" in --light|"") nm="$(basename "${img%.*}" | tr 'A-Z' 'a-z')" ;; esac
  local slug; slug="$(echo "$nm" | tr ' ' '-' | tr -cd '[:alnum:]._-' | tr 'A-Z' 'a-z')"
  gen_palette "$seed" "$gmode"
  # if the image has MORE vivid colours with distinct hues, use them as the
  # real accent trio instead of the synthetic ±30° harmonies
  local extras; extras="$(echo "$hist" | while read -r c; do
      read -r H S L <<<"$(_hsl "$c")"
      awk -v c="$c" -v h="$H" -v s="$S" -v l="$L" 'BEGIN{ p=(l<0.15||l>0.85)?0.3:1; if(s*p>=0.25) printf "%.4f %.0f %s\n", s*p, h, c }'
    done | sort -rn)"
  local seedH; read -r seedH _ _ <<<"$(_hsl "$seed")"
  local a2="" a3="" line2 ch cc
  while read -r _ ch cc; do
    [ -z "$cc" ] && continue
    [ "$cc" = "$seed" ] && continue
    # need ≥25° hue distance from the seed and from each other
    local dh; dh="$(awk -v a="$seedH" -v b="$ch" 'BEGIN{d=a-b; if(d<0)d=-d; if(d>180)d=360-d; print int(d)}')"
    [ "$dh" -lt 25 ] && continue
    if [ -z "$a2" ]; then a2="$cc"
    elif [ -z "$a3" ] && [ "$cc" != "$a2" ]; then
      local h2 d2; read -r h2 _ _ <<<"$(_hsl "$a2")"
      d2="$(awk -v a="$h2" -v b="$ch" 'BEGIN{d=a-b; if(d<0)d=-d; if(d>180)d=360-d; print int(d)}')"
      [ "$d2" -ge 25 ] && a3="$cc"
    fi
  done <<<"$extras"
  if [ -n "$a2" ]; then
    local H2 S2 L2 alo ahi
    if [ "$gmode" = light ]; then alo=0.30 ahi=0.48; else alo=0.50 ahi=0.72; fi
    read -r H2 S2 L2 <<<"$(_hsl "$a2")"
    GEN[accent2]="$(_hex "$H2" "$S2" "$(awk -v l="$L2" -v lo="$alo" -v hi="$ahi" 'BEGIN{if(l<lo)l=lo; if(l>hi)l=hi; printf "%.4f", l}')")"
    info "accent2 from image: #${GEN[accent2]}"
  fi
  if [ -n "$a3" ]; then
    local H3 S3 L3
    read -r H3 S3 L3 <<<"$(_hsl "$a3")"
    GEN[accent3]="$(_hex "$H3" "$S3" "$(awk -v l="$L3" -v lo="$alo" -v hi="$ahi" 'BEGIN{if(l<lo)l=lo; if(l>hi)l=hi; printf "%.4f", l}')")"
    info "accent3 from image: #${GEN[accent3]}"
  fi
  # blend bg toward the image's actual darkest colour for cohesion
  local darkest; darkest="$(echo "$hist" | while read -r c; do
      read -r H S L <<<"$(_hsl "$c")"; awk -v c="$c" -v l="$L" 'BEGIN{printf "%.4f %s\n", l, c}'
    done | sort -n | head -1 | awk '{print $2}')"
  if [ -n "$darkest" ] && [ "$gmode" = dark ]; then
    GEN[bg]="$(_mix_pub "${GEN[bg]}" "$darkest" 0.5)"
    GEN[bg_dim]="$(_mix_pub "${GEN[bg_dim]}" "$darkest" 0.5)"
  fi
  snapshot
  write_generated_theme "$slug" "$nm" "$gmode" wall >/dev/null
  : > "$OVERRIDES"; echo "$slug" > "$STATE"
  apply_theme "$slug" keep
  say "tip: ${BOLD}wear save${NC} tweaks, or re-run with --light"
}

# public mix helper (same math as load_palette's _mix, callable anywhere)
_mix_pub() { awk -v a="$1" -v b="$2" -v f="$3" 'BEGIN{
  ar=strtonum("0x" substr(a,1,2)); ag=strtonum("0x" substr(a,3,2)); ab=strtonum("0x" substr(a,5,2))
  br=strtonum("0x" substr(b,1,2)); bg=strtonum("0x" substr(b,3,2)); bb=strtonum("0x" substr(b,5,2))
  printf "%02x%02x%02x", ar+(br-ar)*f, ag+(bg-ag)*f, ab+(bb-ab)*f }'
}

# wear show — truecolor swatches of the active palette in the terminal
show_palette() {
  load_palette "$(current_theme)" >/dev/null 2>&1
  echo
  echo -e "  ${BOLD}$(pretty_name "$(current_theme)")${NC}  ($(current_theme), ${THEME_MODE})"
  echo
  local k v r g b
  _sw_line() { # label keys...
    local lbl="$1"; shift
    printf '  %-10s' "$lbl"
    for k in "$@"; do
      v="${PAL[$k]}"
      r=$((16#${v:0:2})); g=$((16#${v:2:2})); b=$((16#${v:4:2}))
      printf '\033[48;2;%d;%d;%dm  %s  \033[0m ' "$r" "$g" "$b" "$k"
    done
    echo
  }
  _sw_line accents accent accent2 accent3
  _sw_line surfaces bg bg_alt bg_dim surface overlay
  _sw_line text fg fg_dim fg_faint on_accent
  _sw_line ansi red green yellow blue magenta cyan
  _sw_line bright br_red br_green br_yellow br_blue br_magenta br_cyan
  echo
  if [ -s "$OVERRIDES" ]; then
    echo -e "  ${DIM}tweaks:${NC} $(grep -cvE '^\s*(#|$)' "$OVERRIDES") active — wear tweaks"
  fi
}

# --- interactive picker -----------------------------------------------------
# glyph per theme (falls back to a generic palette icon)
theme_glyph() {
  case "$1" in
    phosphor)          echo "" ;;   # leaf / CRT green
    tokyo-night)       echo "󱑍" ;;   # moon
    gruvbox)           echo "󱄄" ;;   # sun / warm
    catppuccin-mocha)  echo "󱋼" ;;   # coffee
    catppuccin-latte)  echo "󱋿" ;;   # coffee (light)
    nord)              echo "" ;;   # snowflake
    rose-pine)         echo "󰼎" ;;   # flower
    *)                 echo "󰌷" ;;   # palette
  esac
}

pick() {
  local themes slug
  mapfile -t themes < <(list_themes)
  local cur; cur="$(current_theme)"
  # Build pango-markup rows: <glyph>  Name   [● active]  + a coloured swatch.
  # Column 2 (tab-separated) carries the slug for reverse mapping.
  local menu="" slug disp glyph acc dot
  for slug in "${themes[@]}"; do
    disp="$(pretty_name "$slug")"
    glyph="$(theme_glyph "$slug")"
    acc="#$( set -a; . "$THEMES_DIR/$slug.theme"; echo "${accent}" )"
    dot=""
    [ "$slug" = "$cur" ] && dot="   <span foreground='$acc'>● active</span>"
    # █ swatch tinted with the theme accent, then glyph + name
    menu+="<span foreground='$acc'>██</span>  $glyph  <b>$disp</b>$dot\t$slug\n"
  done

  local chosen=""
  local picker="$CFG/rofi/theme-picker.rasi"
  if [ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ] && command -v rofi >/dev/null 2>&1 && [ -f "$picker" ]; then
    # -config /dev/null so we DON'T inherit the combi launcher's fullscreen layout.
    # -markup-rows renders the pango spans; select by the hidden slug column.
    chosen="$(printf '%b' "$menu" | \
      rofi -dmenu -i -markup-rows -config /dev/null -theme "$picker" \
           -display-columns 1 -mesg "switch the whole desktop · Enter to apply" \
           -format 'd')" || return 0
    # -format 'd' returns the 1-based index of the selection
    [ -z "$chosen" ] && return 0
    [ "$chosen" -ge 1 ] 2>/dev/null && { apply_theme "${themes[$((chosen-1))]}"; return; }
    return 0
  elif command -v fzf >/dev/null 2>&1; then
    local sel; sel="$(printf '%s\n' "${themes[@]}" | \
      fzf --prompt='theme> ' --with-nth=1 \
          --preview 'sed -n "1,3p" '"$THEMES_DIR"'/{}.theme')" || return 0
    [ -n "$sel" ] && apply_theme "$sel"
    return 0
  else
    echo "Available themes:"; local i=1
    for slug in "${themes[@]}"; do
      local mark=""; [ "$slug" = "$cur" ] && mark="  (active)"
      echo "  $i) $(pretty_name "$slug")$mark"; i=$((i+1))
    done
    read -rp "pick #: " n
    [ "$n" -ge 1 ] 2>/dev/null && apply_theme "${themes[$((n-1))]}"
    return 0
  fi
}

# ============================================================================
#  TWEAKER UI  (rofi)  —  `wear tweak`
# ============================================================================

# small rofi wrapper: $1=prompt  $2=mesg ; rows on stdin ; prints selection
_rofi() {
  local prompt="$1" mesg="$2"
  rofi -dmenu -i -markup-rows -config /dev/null \
       -theme "$CFG/rofi/theme-picker.rasi" \
       -p "$prompt" -mesg "$mesg" 2>/dev/null
}

# re-render everything, keeping overrides, for an instant live preview
preview() { apply_theme "$(current_theme)" keep >/dev/null 2>&1; }

# swatch markup for a hex value (no #)
_sw() { printf "<span foreground='#%s'>\u2588\u2588\u2588</span>" "$1"; }

# Edit a COLOUR key. Offers hyprpicker (eyedropper), a hex prompt, or presets.
edit_color() { # $1=key $2=label
  local key="$1" label="$2" cur; cur="$(eff_value "$key")"
  local rows=""
  rows+="$(_sw "$cur")  current: <b>#$cur</b>\n"
  command -v hyprpicker >/dev/null 2>&1 && rows+="\ueb28  Pick from screen (eyedropper)\n"
  rows+="\uf040  Type a hex value…\n"
  # a strip of palette colours from the current theme as quick presets
  local pk; for pk in accent accent2 accent3 red green yellow blue magenta cyan fg bg; do
    local pv; pv="$(eff_value "$pk")"
    [ -n "$pv" ] && rows+="$(_sw "$pv")  use $pk (#$pv)\n"
  done
  rows+="\u21ba  reset $key to theme default"
  local sel; sel="$(printf '%b' "$rows" | _rofi "$label" "pick a colour for $label")" || return 0
  [ -z "$sel" ] && return 0
  local newv=""
  case "$sel" in
    *eyedropper*)
      newv="$(hyprpicker -a -f hex 2>/dev/null | tr -d '#\n')" ;;
    *Type\ a\ hex*)
      newv="$(printf '' | _rofi "#hex" "enter 6 hex digits, e.g. ff8800")"
      newv="${newv#\#}" ;;
    *reset*)
      unset_override "$key"; preview; return 0 ;;
    use\ *)
      local src; src="$(echo "$sel" | sed -E 's/.*use ([a-z0-9_]+).*/\1/')"
      newv="$(eff_value "$src")" ;;
    *) return 0 ;;
  esac
  newv="$(echo "$newv" | tr '[:upper:]' '[:lower:]' | tr -cd '[:xdigit:]')"
  [[ "$newv" =~ ^[0-9a-f]{6}$ ]] || { warn "not a 6-digit hex: $newv"; return 0; }
  set_override "$key" "$newv"; preview
}

# Edit a NUMERIC key with a +/- stepper (and a type-exact option).
edit_number() { # $1=key $2=label $3=min $4=max $5=step $6=isfloat(0/1)
  local key="$1" label="$2" min="$3" max="$4" step="$5" isf="$6"
  while :; do
    local cur; cur="$(eff_value "$key")"
    local rows=""
    rows+="current: <b>$cur</b>   <span size='small'>($min–$max)</span>\n"
    rows+="\uf077  + $step\n"
    rows+="\uf078  − $step\n"
    rows+="\uf055  max ($max)\n"
    rows+="\uf056  min ($min)\n"
    rows+="\uf040  type exact value…\n"
    rows+="\u21ba  reset to theme default\n"
    rows+="\uf00c  done"
    local sel; sel="$(printf '%b' "$rows" | _rofi "$label" "adjust $label · Esc to go back")" || return 0
    [ -z "$sel" ] && return 0
    local nv="$cur"
    case "$sel" in
      *"+ "*)  nv="$(awk -v c="$cur" -v s="$step" -v m="$max" 'BEGIN{v=c+s; if(v>m)v=m; print v}')" ;;
      *"− "*)  nv="$(awk -v c="$cur" -v s="$step" -v m="$min" 'BEGIN{v=c-s; if(v<m)v=m; print v}')" ;;
      *max*)   nv="$max" ;;
      *min*)   nv="$min" ;;
      *type*)  nv="$(printf '' | _rofi "$label=" "enter a number between $min and $max")" ;;
      *reset*) unset_override "$key"; preview; continue ;;
      *done*)  return 0 ;;
      *) return 0 ;;
    esac
    [ -z "$nv" ] && continue
    # integers: strip decimals
    [ "$isf" = "0" ] && nv="$(awk -v v="$nv" 'BEGIN{printf "%d", v}')"
    set_override "$key" "$nv"; preview
  done
}

# Edit a CHOICE key from a fixed comma list.
edit_choice() { # $1=key $2=label $3=csv
  local key="$1" label="$2" csv="$3" cur; cur="$(eff_value "$key")"
  local rows="" opt
  local IFS=,; for opt in $csv; do
    local mark=""; [ "$opt" = "$cur" ] && mark="  ●"
    rows+="$opt$mark\n"
  done
  rows+="\u21ba  reset to theme default"
  local sel; sel="$(printf '%b' "$rows" | _rofi "$label" "choose $label (current: $cur)")" || return 0
  [ -z "$sel" ] && return 0
  case "$sel" in
    *reset*) unset_override "$key"; preview; return 0 ;;
    *) set_override "$key" "$(echo "$sel" | sed 's/  ●$//' | tr -d ' ')"; preview ;;
  esac
}

# Edit a FONT key from fontconfig families.
edit_font() { # $1=key $2=label
  local key="$1" label="$2" cur; cur="$(eff_value "$key")"
  local list
  if command -v fc-list >/dev/null 2>&1; then
    list="$(fc-list : family | sed 's/,.*//' | sort -u)"
  else
    list=$'JetBrainsMono Nerd Font\nInter\nCantarell\nNoto Sans\nFira Code'
  fi
  local sel; sel="$(printf 'current: %s\n%s' "$cur" "$list" | _rofi "$label" "pick a font family")" || return 0
  [ -z "$sel" ] && return 0
  case "$sel" in current:*) return 0 ;; esac
  set_override "$key" "$sel"; preview
}

# Edit a PICK key: options discovered on disk (gtk/icon/cursor/kvantum/shader).
edit_pick() { # $1=key $2=label $3=kind
  local key="$1" label="$2" kind="$3" cur; cur="$(eff_value "$key")"
  local opts; opts="$(list_options "$kind")"
  [ -z "$opts" ] && { warn "no $kind options found on this system"; return 0; }
  local sel; sel="$(printf 'current: %s\n↺ reset to theme default\n%s' "$cur" "$opts" \
      | _rofi "$label" "pick $label (current: $cur)")" || return 0
  [ -z "$sel" ] && return 0
  case "$sel" in
    current:*) return 0 ;;
    *reset*)   unset_override "$key"; preview; return 0 ;;
    *)         set_override "$key" "$sel"; preview ;;
  esac
}

# Dispatch to the right editor based on the schema type.
edit_prop() { # $1=key $2=label $3=type $4=spec
  case "$3" in
    color)  edit_color  "$1" "$2" ;;
    int:*)  local a; IFS=: read -r _ mn mx st <<<"$3"; edit_number "$1" "$2" "$mn" "$mx" "$st" 0 ;;
    float:*) IFS=: read -r _ mn mx st <<<"$3"; edit_number "$1" "$2" "$mn" "$mx" "$st" 1 ;;
    choice) edit_choice "$1" "$2" "$4" ;;
    font)   edit_font   "$1" "$2" ;;
    pick:*) edit_pick   "$1" "$2" "${3#pick:}" ;;
  esac
}

# Randomise the WHOLE palette — with taste. Picks a random seed hue, then
# derives a full cohesive palette from it (tinted backgrounds, surfaces,
# foregrounds and ANSI slots — the exact keys that drive GTK, Qt and KDE),
# and lays a random colour-harmony accent trio on top. Backgrounds carry a
# whisper of the accent hue so the desktop reads as one designed thing, not
# three loud swatches on a grey box. Mode (dark/light) is preserved.
# Every roll is different; none of them are ugly.
randomise_accents() {
  load_palette "$(current_theme)" >/dev/null 2>&1
  local gmode="${THEME_MODE:-dark}"
  local h=$((RANDOM % 360)) strat=$((RANDOM % 6))
  local lo hi
  if [ "$gmode" = light ]; then lo=32 hi=48; else lo=56 hi=70; fi
  local L=$(( lo + RANDOM % (hi - lo) )) name h2 h3 s1 s2 s3 l1 l2 l3
  # defaults: full-ish saturation, same lightness across the trio
  s1=$((70 + RANDOM % 25)); s2=$s1; s3=$s1; l1=$L; l2=$L; l3=$L
  case $strat in
    0) name="complementary"; h2=$(( (h + 180) % 360 )); h3=$(( (h + 30)  % 360 )) ;;
    1) name="triad";         h2=$(( (h + 120) % 360 )); h3=$(( (h + 240) % 360 )) ;;
    2) name="analogous";     h2=$(( (h + 30)  % 360 )); h3=$(( (h + 330) % 360 )) ;;
    3) name="pastel";        h2=$(( (h + 90)  % 360 )); h3=$(( (h + 180) % 360 ))
       s1=$((35 + RANDOM % 15)); s2=$s1; s3=$s1
       l1=$((l1 + 12)); l2=$l1; l3=$l1 ;;
    4) name="neon";          h2=$(( (h + 150) % 360 )); h3=$(( (h + 210) % 360 ))
       s1=100; s2=100; s3=100
       if [ "$gmode" != light ]; then l1=60; l2=60; l3=60; fi ;;
    5) name="monochrome";    h2=$h; h3=$h
       l2=$(( l1 + 14 )); l3=$(( l1 > 18 ? l1 - 14 : l1 + 26 ))
       s2=$(( s1 - 20 )); s3=$s1 ;;
  esac

  # 1) derive a FULL cohesive palette from the seed hue (this is what feeds
  #    GTK/Qt/KDE: bg, bg_alt, bg_dim, surface, overlay, fg, fg_dim, fg_faint,
  #    on_accent, br_black/br_white, plus semantic ANSI colours).
  local seed; seed="$(_hex "$h" "$(awk -v s=$s1 'BEGIN{print s/100}')" "$(awk -v l=$l1 'BEGIN{print l/100}')")"
  declare -gA GEN=()
  gen_palette "$seed" "$gmode"
  # backgrounds/surfaces keep only a WHISPER of the seed hue (gen_palette
  # already tints them ~0.18-0.28 sat); that subtle tint is what makes GTK
  # window chrome feel part of the theme instead of neutral grey.
  local k
  for k in bg bg_alt bg_dim surface overlay fg fg_dim fg_faint on_accent \
           br_black br_white red green yellow blue magenta cyan \
           br_red br_green br_yellow br_blue br_magenta br_cyan; do
    set_override "$k" "${GEN[$k]}"
  done

  # 2) lay the harmonised accent trio on top (overrides gen_palette's ±30°)
  set_override accent  "$(_hex "$h"  "$(awk -v s=$s1 'BEGIN{print s/100}')" "$(awk -v l=$l1 'BEGIN{print l/100}')")"
  set_override accent2 "$(_hex "$h2" "$(awk -v s=$s2 'BEGIN{print s/100}')" "$(awk -v l=$l2 'BEGIN{print l/100}')")"
  set_override accent3 "$(_hex "$h3" "$(awk -v s=$s3 'BEGIN{print s/100}')" "$(awk -v l=$l3 'BEGIN{print l/100}')")"

  # 3) body text (fg) must read on the tinted background (GTK/Qt text).
  if ! awk -v r="$(_contrast "${GEN[fg]}" "${GEN[bg]}")" 'BEGIN{exit (r>=4.5)?0:1}'; then
    [ "$gmode" = light ] && set_override fg "1a1a1a" || set_override fg "ececec"
  fi

  # 4) semantic colours + accents must clear 3:1 on bg (they read as text:
  #    errors/warnings/success, GTK links, terminal). Light backgrounds are
  #    unforgiving — walk any failing colour's lightness toward the bg's
  #    opposite pole until it passes (hue/sat kept, so it stays on-palette).
  local bg="${GEN[bg]}" ck cv cH cS cL cdir ctry
  for ck in accent accent2 accent3 red green yellow blue magenta cyan; do
    cv="$(eff_value "$ck")"
    awk -v r="$(_contrast "$cv" "$bg")" 'BEGIN{exit (r>=3.0)?0:1}' && continue
    read -r cH cS cL <<<"$(_hsl "$cv")"
    [ "$gmode" = light ] && cdir=-1 || cdir=1     # light bg: darken; dark bg: lighten
    ctry=0
    while [ $ctry -lt 24 ]; do
      cL="$(awk -v l="$cL" -v d="$cdir" 'BEGIN{l+=d*0.03; if(l>0.97)l=0.97; if(l<0.03)l=0.03; printf "%.4f", l}')"
      cv="$(_hex "$cH" "$cS" "$cL")"
      awk -v r="$(_contrast "$cv" "$bg")" 'BEGIN{exit (r>=3.0)?0:1}' && break
      ctry=$((ctry+1))
    done
    set_override "$ck" "$cv"
    # keep bright ANSI a step above its base
    case "$ck" in red|green|yellow|blue|magenta|cyan)
      set_override "br_$ck" "$(_color_op "$cv" lighter:18)" ;;
    esac
  done

  # 5) on_accent must read on the FINAL accent (step 4 may have moved it).
  #    Prefer the tinted bg (cohesive), else a near-pole, else the readable
  #    pure pole — guarantees the 4.5:1 needed for text on accent fills.
  local acc oa
  acc="$(eff_value accent)"
  if awk -v r="$(_contrast "${GEN[bg]}" "$acc")" 'BEGIN{exit (r>=4.5)?0:1}'; then
    oa="${GEN[bg]}"
  else
    local base; [ "$gmode" = light ] && base="f8f8f8" || base="101010"
    if awk -v r="$(_contrast "$base" "$acc")" 'BEGIN{exit (r>=4.5)?0:1}'; then
      oa="$base"
    else
      local rb rw; rb="$(_contrast 000000 "$acc")"; rw="$(_contrast ffffff "$acc")"
      oa="$(awk -v b="$rb" -v w="$rw" 'BEGIN{print (w>=b)?"ffffff":"000000"}')"
    fi
  fi
  set_override on_accent "$oa"

  RANDOM_STRATEGY="$name · hue $h°"
}

# --- section randomisers -----------------------------------------------------
# Only STYLE gets rolled — never functional choices (bar modules, clock style,
# notification timeout, fonts, layout, icon/cursor themes stay yours).
# Ranges are tasteful sub-bands of the schema, so every roll is livable.
_rint()   { echo $(( $1 + RANDOM % ($2 - $1 + 1) )); }             # int in [a,b]
_reven()  { local v; v=$(_rint "$1" "$2"); echo $(( v / 2 * 2 )); } # even int
_rfloat() { awk -v lo="$1" -v hi="$2" -v r="$RANDOM" 'BEGIN{printf "%.2f", lo+(hi-lo)*r/32768}'; }
_rpick()  { local -a a=("$@"); echo "${a[RANDOM % ${#a[@]}]}"; }   # repeat args to bias

randomise_shape() {
  set_override radius       "$(_reven 0 22)"
  set_override border_width "$(_rint 1 3)"
  local gi; gi="$(_reven 2 14)"
  set_override gap_in  "$gi"
  set_override gap_out "$(( gi + $(_reven 2 12) ))"
}

randomise_feel() {
  local oa; oa="$(_rfloat 0.85 1.0)"
  set_override opacity_active   "$oa"
  set_override opacity_inactive "$(awk -v a="$oa" -v d="$(_rfloat 0.04 0.15)" 'BEGIN{v=a-d; if(v<0.6)v=0.6; printf "%.2f", v}')"
  set_override blur_size     "$(_rint 4 12)"
  set_override blur_passes   "$(_rint 2 4)"
  set_override blur_vibrancy "$(_rfloat 0.05 0.50)"
  set_override blur_noise    "$(_rfloat 0.01 0.04)"
  set_override blur_contrast "$(_rfloat 0.90 1.15)"
  set_override blur_brightness "$(_rfloat 0.85 1.10)"
  set_override glow          "$(_rfloat 0.00 0.60)"
  set_override anim_speed    "$(_rint 3 8)"
  set_override anim_style    "$(_rpick slide popin fade)"
  set_override term_opacity  "$(_rfloat 0.80 1.0)"
  set_override term_padding  "$(_reven 6 20)"
}

randomise_bar() {
  set_override bar_position "$(_rpick top top top bottom)"   # biased: top
  set_override bar_height   "$(_reven 26 40)"
  local m; m="$(_reven 0 12)"
  set_override bar_margin   "$m"                             # gap to hugged edge
  set_override bar_margin_x "$(_reven 0 16)"                 # side gap (independent)
  set_override bar_spacing  "$(_rint 2 10)"
  # docked bar (no margin) looks best square; floating bar gets rounded pills
  if [ "$m" -eq 0 ]; then set_override bar_radius 0
  else set_override bar_radius "$(_reven 6 18)"; fi
  set_override bar_opacity      "$(_rfloat 0.70 1.0)"
  set_override bar_border_width "$(_rint 0 2)"
}

randomise_popups() {
  set_override rofi_width     "$(( $(_rint 24 40) * 20 ))"   # 480–800, step 20
  set_override rofi_lines     "$(_rint 6 12)"
  set_override notif_width    "$(( $(_rint 15 23) * 20 ))"   # 300–460, step 20
  set_override notif_position "$(_rpick top-right top-right top-left bottom-right)"
}

# Main tweaker menu: flat list of every editable property + actions.
tweak() {
  if ! { [ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ] && command -v rofi >/dev/null 2>&1; }; then
    warn "the tweaker needs rofi in a graphical session"; return 1
  fi
  local cur_theme; cur_theme="$(current_theme)"
  while :; do
    load_palette "$cur_theme" >/dev/null 2>&1
    local rows="" line key label type spec
    # header actions
    rows+="\uf043  <b>Base theme</b>: $(pretty_name "$cur_theme")\t@base\n"
    rows+="\uf5aa  <b>Random colours</b> \uf522  <span size='small'>(full palette)</span>\t@random\n"
    rows+="\uf522  <b>Random everything</b>  <span size='small'>(style only)</span>\t@chaos\n"
    rows+="\uf0c7  <b>Save as new theme…</b>\t@save\n"
    local ntweaks=0; [ -f "$OVERRIDES" ] && ntweaks=$(grep -cvE '^\s*(#|$)' "$OVERRIDES" 2>/dev/null || echo 0)
    rows+="\u21ba  <b>Reset all tweaks</b>  <span size='small'>($ntweaks active)</span>\t@reset\n"
    # every schema property, grouped by ## headers
    while IFS= read -r line; do
      case "$line" in
        '##'*) rows+="<span size='small' weight='bold'>── ${line#\#\# } ──</span>\t@sep\n"; continue ;;
        '') continue ;;
      esac
      IFS='|' read -r key label type spec <<<"$line"
      local val; val="${PAL[$key]:-}"; local badge=""
      # show swatch for colours, plain value otherwise; * marks an override
      grep -qE "^\s*${key}=" "$OVERRIDES" 2>/dev/null && badge=" <span foreground='#$(eff_value accent)'>•</span>"
      if [ "$type" = color ]; then
        rows+="$(_sw "$val")  $label  <span size='small'>#$val</span>$badge\t$key|$label|$type|$spec\n"
      else
        rows+="\u2003 $label  <b>$val</b>$badge\t$key|$label|$type|$spec\n"
      fi
    done < <(tweak_schema)

    local sel; sel="$(printf '%b' "$rows" | rofi -dmenu -i -markup-rows -config /dev/null \
        -theme "$CFG/rofi/theme-picker.rasi" -p 'tweak' \
        -mesg 'live appearance · changes apply instantly · Esc to exit' \
        -display-columns 1 -format 's')" || return 0
    [ -z "$sel" ] && return 0
    # the payload is after the last tab
    local payload="${sel##*	}"
    case "$payload" in
      @sep)   continue ;;
      @base)  local t; mapfile -t _ts < <(list_themes)
              t="$(printf '%s\n' "${_ts[@]}" | _rofi 'base theme' 'switch base (clears tweaks)')"
              [ -n "$t" ] && [ -f "$THEMES_DIR/$t.theme" ] && { apply_theme "$t" >/dev/null 2>&1; cur_theme="$t"; } ;;
      @random) randomise_accents; preview ;;
      @chaos)  randomise_accents; randomise_shape; randomise_feel; randomise_bar; randomise_popups; preview ;;
      @save)  local nm; nm="$(printf '' | _rofi 'save as' 'name for the new theme')"
              [ -n "$nm" ] && { save_theme "$nm"; cur_theme="$(current_theme)"; } ;;
      @reset) : > "$OVERRIDES"; preview ;;
      *|*)    IFS='|' read -r key label type spec <<<"$payload"
              [ -n "$key" ] && edit_prop "$key" "$label" "$type" "$spec" ;;
    esac
  done
}

# ============================================================================
#  SMART LAYER — fuzzy matching, colour maths, WCAG, mode flip, base16
# ============================================================================

COLOR_KEYS="bg bg_alt bg_dim surface overlay fg fg_dim fg_faint accent accent2 accent3 on_accent red green yellow blue magenta cyan br_black br_red br_green br_yellow br_blue br_magenta br_cyan br_white"

# levenshtein distance (awk)
_lev() { awk -v a="$1" -v b="$2" 'BEGIN{
  la=length(a); lb=length(b)
  for(i=0;i<=la;i++)d[i,0]=i
  for(j=0;j<=lb;j++)d[0,j]=j
  for(i=1;i<=la;i++)for(j=1;j<=lb;j++){
    c=(substr(a,i,1)==substr(b,j,1))?0:1
    m=d[i-1,j]+1; if(d[i,j-1]+1<m)m=d[i,j-1]+1; if(d[i-1,j-1]+c<m)m=d[i-1,j-1]+c
    d[i,j]=m }
  print d[la,lb] }'
}

# _match <needle>  (candidates on stdin, one per line)
# exact → ci-exact → unique prefix → unique substring → fuzzy (lev ≤ 3).
_match() {
  local n="$1" ln c d best=999 bm=""; ln="${n,,}"
  local -a cands=() hits=()
  mapfile -t cands
  for c in "${cands[@]}"; do [ "$c" = "$n" ] && { printf '%s' "$c"; return 0; }; done
  for c in "${cands[@]}"; do [ "${c,,}" = "$ln" ] && { printf '%s' "$c"; return 0; }; done
  hits=(); for c in "${cands[@]}"; do [[ "${c,,}" == "$ln"* ]] && hits+=("$c"); done
  [ ${#hits[@]} -eq 1 ] && { printf '%s' "${hits[0]}"; return 0; }
  hits=(); for c in "${cands[@]}"; do [[ "${c,,}" == *"$ln"* ]] && hits+=("$c"); done
  [ ${#hits[@]} -eq 1 ] && { printf '%s' "${hits[0]}"; return 0; }
  if [ ${#hits[@]} -gt 1 ]; then
    # several contain it — take the closest by edit distance (shortest wins ties)
    printf '%s' "$(for c in "${hits[@]}"; do echo "$(_lev "$ln" "${c,,}") ${#c} $c"; done | sort -n -k1,1 -k2,2 | head -1 | cut -d' ' -f3-)"
    return 0
  fi
  for c in "${cands[@]}"; do
    [ -z "$c" ] && continue
    local lc="${c,,}"
    d="$(_lev "$ln" "$lc")"
    # also try against a same-length prefix (catches tokio→tokyo-night)
    local pd; pd="$(_lev "$ln" "${lc:0:${#ln}}")"; pd=$((pd+1))
    [ "$pd" -lt "$d" ] && d=$pd
    if [ "$d" -lt "$best" ]; then best=$d; bm="$c"; fi
  done
  if [ -n "$bm" ] && [ "$best" -le 3 ] && [ "$best" -lt "${#n}" ]; then printf '%s' "$bm"; return 0; fi
  return 1
}

# CSS named colours → rrggbb (the ones humans actually type)
_named_color() {
  case "${1,,}" in
    black) echo 000000;; white) echo ffffff;; red) echo ff0000;;
    green) echo 008000;; lime) echo 00ff00;; blue) echo 0000ff;;
    yellow) echo ffff00;; cyan|aqua) echo 00ffff;; magenta|fuchsia) echo ff00ff;;
    orange) echo ffa500;; purple) echo 800080;; pink) echo ffc0cb;;
    hotpink) echo ff69b4;; deeppink) echo ff1493;; brown) echo a52a2a;;
    chocolate) echo d2691e;; coral) echo ff7f50;; tomato) echo ff6347;;
    salmon) echo fa8072;; crimson) echo dc143c;; maroon) echo 800000;;
    olive) echo 808000;; gold) echo ffd700;; khaki) echo f0e68c;;
    tan) echo d2b48c;; beige) echo f5f5dc;; teal) echo 008080;;
    turquoise) echo 40e0d0;; navy) echo 000080;; indigo) echo 4b0082;;
    violet) echo ee82ee;; orchid) echo da70d6;; plum) echo dda0dd;;
    lavender) echo e6e6fa;; skyblue) echo 87ceeb;; steelblue) echo 4682b4;;
    slateblue) echo 6a5acd;; royalblue) echo 4169e1;; dodgerblue) echo 1e90ff;;
    midnightblue) echo 191970;; seagreen) echo 2e8b57;; forestgreen) echo 228b22;;
    springgreen) echo 00ff7f;; chartreuse) echo 7fff00;; rebeccapurple) echo 663399;;
    silver) echo c0c0c0;; gray|grey) echo 808080;; dimgray|dimgrey) echo 696969;;
    slategray|slategrey) echo 708090;; firebrick) echo b22222;; sienna) echo a0522d;;
    wheat) echo f5deb3;; peachpuff) echo ffdab9;; darkred) echo 8b0000;;
    darkgreen) echo 006400;; darkblue) echo 00008b;; darkorange) echo ff8c00;;
    darkviolet) echo 9400d3;; deepskyblue) echo 00bfff;; lightblue) echo add8e6;;
    lightgreen) echo 90ee90;; lightgray|lightgrey) echo d3d3d3;;
    aquamarine) echo 7fffd4;; cadetblue) echo 5f9ea0;; goldenrod) echo daa520;;
    thistle) echo d8bfd8;; mint|mintcream) echo f5fffa;; ivory) echo fffff0;;
