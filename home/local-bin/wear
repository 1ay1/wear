# normalise any colour spelling → rrggbb:  #abc / abc / #aabbcc / aabbcc / css name
_norm_color() {
  local c="${1#\#}"
  if [[ "$c" =~ ^[0-9a-fA-F]{6}$ ]]; then printf '%s' "${c,,}"; return 0; fi
  if [[ "$c" =~ ^[0-9a-fA-F]{3}$ ]]; then
    c="${c,,}"; printf '%s%s%s%s%s%s' "${c:0:1}" "${c:0:1}" "${c:1:1}" "${c:1:1}" "${c:2:1}" "${c:2:1}"; return 0
  fi
  _named_color "$c"
}

# _color_op <hex> <op[:pct]> → new hex. ops: lighter darker saturate desaturate complement invert
_color_op() {
  local cur="$1" op="$2" pct=15 H S L
  case "$op" in *:*) pct="${op#*:}"; op="${op%%:*}";; esac
  [[ "$pct" =~ ^[0-9]+$ ]] || pct=15
  if [ "$op" = invert ]; then
    awk -v h="$cur" 'BEGIN{printf "%02x%02x%02x", 255-strtonum("0x" substr(h,1,2)), 255-strtonum("0x" substr(h,3,2)), 255-strtonum("0x" substr(h,5,2))}'
    return 0
  fi
  read -r H S L <<<"$(_hsl "$cur")"
  case "$op" in
    lighter|lighten)  L="$(awk -v l="$L" -v p="$pct" 'BEGIN{l+=(1-l)*p/100; if(l>1)l=1; printf "%.4f", l}')" ;;
    darker|darken)    L="$(awk -v l="$L" -v p="$pct" 'BEGIN{l-=l*p/100; if(l<0)l=0; printf "%.4f", l}')" ;;
    saturate|vivid)   S="$(awk -v s="$S" -v p="$pct" 'BEGIN{s+=(1-s)*p/100; if(s>1)s=1; printf "%.4f", s}')" ;;
    desaturate|mute)  S="$(awk -v s="$S" -v p="$pct" 'BEGIN{s-=s*p/100; if(s<0)s=0; printf "%.4f", s}')" ;;
    complement)       H="$(awk -v h="$H" 'BEGIN{printf "%.1f", (h+180)%360}')" ;;
    *) return 1 ;;
  esac
  _hex "$H" "$S" "$L"
}

# WCAG contrast ratio between two hex colours (proper sRGB linearisation)
_contrast() { awk -v a="$1" -v b="$2" '
  function ch(x){ x/=255; return x<=0.03928 ? x/12.92 : ((x+0.055)/1.055)^2.4 }
  function lum(h){ return 0.2126*ch(strtonum("0x" substr(h,1,2))) \
                        +0.7152*ch(strtonum("0x" substr(h,3,2))) \
                        +0.0722*ch(strtonum("0x" substr(h,5,2))) }
  BEGIN{ l1=lum(a); l2=lum(b); if(l1<l2){t=l1;l1=l2;l2=t}
         printf "%.2f", (l1+0.05)/(l2+0.05) }'
}

# schema line for a key: "key|Label|type|spec" (empty if not in schema)
_schema_line() { tweak_schema | grep -m1 "^${1}|" || true; }

# all settable keys (schema + engine escape hatches)
_all_keys() {
  tweak_schema | grep -vE '^(##|$)' | cut -d'|' -f1
  printf '%s\n' gtk_theme qt_style kvantum_theme anim_bezier
}

# smart_set <key-ish> <value-ish>: fuzzy key, smart value, validation, clamps.
#   values: colours (name/#abc/hex), ops (lighter/darker/saturate/desaturate/
#   complement/invert[:pct]), numbers (+4 -2 ++ -- 2x .5x or absolute, clamped),
#   choices/picks fuzzy-matched against real options, default = reset key.
smart_set() {
  local rawk="$1" rawv="$2" key line label type spec cur new=""
  key="$(_all_keys | _match "$rawk")" || {
    warn "unknown property: $rawk"
    info "closest: $(_all_keys | while read -r k; do echo "$(_lev "$rawk" "$k") $k"; done | sort -n | head -3 | awk '{print $2}' | paste -sd' ')"
    return 1; }
  [ "$key" != "$rawk" ] && info "$rawk → ${BOLD}$key${NC}"
  line="$(_schema_line "$key")"
  IFS='|' read -r _ label type spec <<<"$line"
  [ -z "$type" ] && type=raw
  cur="$(eff_value "$key")"

  # "default" / "reset" → unset the override
  case "${rawv,,}" in
    default|reset|base)
      snapshot; unset_override "$key"; apply_theme "$(current_theme)" keep
      say "$key → back to base ($(eff_value "$key"))"; return 0 ;;
  esac

  case "$type" in
    color)
      # colour op on the current value?
      case "${rawv,,}" in
        lighter*|lighten*|darker*|darken*|saturate*|vivid*|desaturate*|mute*|complement|invert)
          new="$(_color_op "$cur" "${rawv,,}")" || true ;;
      esac
      [ -z "$new" ] && new="$(_norm_color "$rawv")" || true
      [ -z "$new" ] && { warn "'$rawv' is not a colour (try a name, #abc, aabbcc, or lighter/darker[:pct])"; return 1; } ;;
    int:*|float:*)
      local mn mx st isf=0; IFS=: read -r _ mn mx st <<<"$type"
      [[ "$type" == float:* ]] && isf=1
      case "$rawv" in
        ++)      new="$(awk -v c="$cur" -v s="$st" 'BEGIN{print c+s}')" ;;
        --)      new="$(awk -v c="$cur" -v s="$st" 'BEGIN{print c-s}')" ;;
        max|full) new="$mx" ;;
        min|none|off) new="$mn" ;;
        +*)      new="$(awk -v c="$cur" -v d="${rawv#+}" 'BEGIN{print c+d}')" ;;
        -*)      new="$(awk -v c="$cur" -v d="${rawv#-}" 'BEGIN{print c-d}')" ;;
        *[0-9]x|*[0-9]X) new="$(awk -v c="$cur" -v f="${rawv%[xX]}" 'BEGIN{print c*f}')" ;;
        *)       new="$rawv" ;;
      esac
      awk -v n="$new" 'BEGIN{exit (n+0==n)?0:1}' 2>/dev/null || { warn "'$rawv' is not a number for $key"; return 1; }
      # clamp into schema range and round to step grid
      new="$(awk -v n="$new" -v mn="$mn" -v mx="$mx" -v f="$isf" 'BEGIN{
        if(n<mn)n=mn; if(n>mx)n=mx
        if(f) printf "%.2f", n; else printf "%d", n+0.5 }')" ;;
    choice)
      new="$(printf '%s\n' ${spec//,/ } | _match "$rawv")" || { warn "$key must be one of: ${spec//,/ / }"; return 1; } ;;
    pick:*)
      local kind="${type#pick:}"
      new="$(list_options "$kind" | _match "$rawv")" || { warn "no $kind matching '$rawv' (see: wear options $kind)"; return 1; } ;;
    font)
      new="$(fc-list : family 2>/dev/null | tr ',' '\n' | sort -u | _match "$rawv" || true)"
      [ -z "$new" ] && new="$rawv" ;;
    *) new="$rawv" ;;
  esac

  [ "$new" = "$cur" ] && { info "$key already $cur"; return 0; }
  snapshot; set_override "$key" "$new"; apply_theme "$(current_theme)" keep
  if [ "$type" = color ]; then
    say "$key: $(printf '\033[48;2;%d;%d;%dm  \033[0m' $((16#${cur:0:2})) $((16#${cur:2:2})) $((16#${cur:4:2}))) #$cur → $(printf '\033[48;2;%d;%d;%dm  \033[0m' $((16#${new:0:2})) $((16#${new:2:2})) $((16#${new:4:2}))) #$new"
  else
    say "$key: $cur → ${BOLD}$new${NC}"
  fi
}

# flip_mode <dark|light|toggle> — re-derive the WHOLE palette for the other
# polarity while keeping every hue. Works on any theme, applied as overrides
# so `wear undo` / base reset gets you back.
flip_mode() {
  local want="$1" cur k v H S L
  load_palette "$(current_theme)" >/dev/null 2>&1
  cur="$THEME_MODE"
  [ "$want" = toggle ] && { [ "$cur" = dark ] && want=light || want=dark; }
  [ "$want" = "$cur" ] && { info "already $cur"; return 0; }
  say "flipping ${BOLD}$(pretty_name "$(current_theme)")${NC} → $want (hues preserved)"
  snapshot
  set_override mode "$want"
  # backgrounds/foregrounds: mirror lightness around 0.5, damp bg saturation
  for k in bg bg_alt bg_dim surface overlay fg fg_dim fg_faint on_accent; do
    v="${PAL[$k]}"; read -r H S L <<<"$(_hsl "$v")"
    set_override "$k" "$(_hex "$H" "$S" "$(awk -v l="$L" 'BEGIN{printf "%.4f", 1-l}')")"
  done
  # accents + ANSI: keep hue/sat, nudge lightness into the readable band
  local lo hi
  if [ "$want" = light ]; then lo=0.30 hi=0.48; else lo=0.55 hi=0.72; fi
  for k in accent accent2 accent3 red green yellow blue magenta cyan \
           br_red br_green br_yellow br_blue br_magenta br_cyan; do
    v="${PAL[$k]}"; read -r H S L <<<"$(_hsl "$v")"
    L="$(awk -v l="$L" -v lo="$lo" -v hi="$hi" 'BEGIN{if(l<lo)l=lo; if(l>hi)l=hi; printf "%.4f", l}')"
    set_override "$k" "$(_hex "$H" "$S" "$L")"
  done
  for k in br_black br_white; do
    v="${PAL[$k]}"; read -r H S L <<<"$(_hsl "$v")"
    set_override "$k" "$(_hex "$H" "$S" "$(awk -v l="$L" 'BEGIN{printf "%.4f", 1-l}')")"
  done
  apply_theme "$(current_theme)" keep
  info "like it? wear save $(current_theme)-$want · hate it? wear undo"
}

# doctor [--fix] — audit the active look: WCAG contrast on every text/bg
# pairing that actually occurs in the desktop, plus sanity checks. --fix
# nudges failing colours (lightness only, hue untouched) until they pass.
doctor() {
  local fix=0; [ "${1:-}" = --fix ] && fix=1
  load_palette "$(current_theme)" >/dev/null 2>&1
  local fails=0 checks=0
  say "auditing ${BOLD}$(pretty_name "$(current_theme)")${NC} (WCAG AA)"

  # pair: fg-key bg-key min-ratio description
  _check() {
    local fk="$1" bk="$2" min="$3" what="$4"
    local f="${PAL[$fk]}" b="${PAL[$bk]}" r
    r="$(_contrast "$f" "$b")"; checks=$((checks+1))
    if awk -v r="$r" -v m="$min" 'BEGIN{exit (r>=m)?0:1}'; then
      printf '   \033[32m✓\033[0m %-28s %5s:1  (%s on %s)\n' "$what" "$r" "$fk" "$bk"
    else
      fails=$((fails+1))
      printf '   \033[31m✗\033[0m %-28s %5s:1  needs %s:1  (%s on %s)\n' "$what" "$r" "$min" "$fk" "$bk"
      if [ "$fix" = 1 ]; then
        # walk the FG colour's lightness away from the bg until it passes
        local H S L dir new tries=0
        read -r H S L <<<"$(_hsl "$f")"
        local bl; read -r _ _ bl <<<"$(_hsl "$b")"
        dir="$(awk -v l="$L" -v bl="$bl" 'BEGIN{print (l>=bl)?1:-1}')"
        new="$f"
        while [ $tries -lt 20 ]; do
          L="$(awk -v l="$L" -v d="$dir" 'BEGIN{l+=d*0.04; if(l>0.98)l=0.98; if(l<0.02)l=0.02; printf "%.4f", l}')"
          new="$(_hex "$H" "$S" "$L")"
          awk -v r="$(_contrast "$new" "$b")" -v m="$min" 'BEGIN{exit (r>=m)?0:1}' && break
          tries=$((tries+1))
        done
        set_override "$fk" "$new"
        printf '     \033[33m↳ fixed\033[0m %s: #%s → #%s  (%s:1)\n' "$fk" "$f" "$new" "$(_contrast "$new" "$b")"
        PAL[$fk]="$new"
      fi
    fi
  }

  echo
  _check fg        bg      4.5 "body text"
  _check fg        bg_alt  4.5 "text on panels/bar"
  _check fg        surface 4.5 "text on cards/popups"
  _check fg_dim    bg      3.0 "secondary text"
  _check accent    bg      3.0 "accent on background"
  _check on_accent accent  4.5 "text on accent fills"
  _check red       bg      3.0 "errors"
  _check yellow    bg      3.0 "warnings"
  _check green     bg      3.0 "success"
  _check br_black  bg      2.0 "comments (terminal)"
  echo

  # structural sanity
  local w="${PAL[border_width]:-2}" oa="${PAL[opacity_active]:-1}"
  awk -v o="$oa" 'BEGIN{exit (o<0.75)?0:1}' && \
    info "note: active opacity $oa is very transparent — text may shimmer over wallpapers"
  [ "${PAL[blur_size]:-0}" -gt 12 ] && [ "${PAL[blur_passes]:-0}" -gt 3 ] 2>/dev/null && \
    info "note: blur ${PAL[blur_size]}px × ${PAL[blur_passes]} passes is heavy on the GPU"

  if [ "$fails" = 0 ]; then
    say "all $checks contrast checks pass — this theme is easy on the eyes"
  elif [ "$fix" = 1 ]; then
    apply_theme "$(current_theme)" keep
    say "$fails issue(s) fixed live — wear undo to revert, wear save <name> to keep"
  else
    warn "$fails of $checks checks fail — run ${BOLD}wear doctor --fix${NC} to auto-correct"
    return 1
  fi
}

# import <file.yaml|url> [name] — wear any of the ~250 community base16
# schemes. Accepts classic (base00: "..") and modern (palette:) layouts.
import_scheme() {
  local src="${1:-}" nm="${2:-}" tmp="" body
  [ -z "$src" ] && { warn "usage: wear import <base16.yaml | url> [name]"; return 1; }
  if [[ "$src" =~ ^https?:// ]]; then
    # github blob links → raw
    src="${src/github.com/raw.githubusercontent.com}"; src="${src//\/blob\//\/}"
    tmp="$(mktemp)"; curl -fsSL "$src" -o "$tmp" 2>/dev/null || { rm -f "$tmp"; warn "could not fetch $src"; return 1; }
    body="$tmp"
  else
    [ -f "$src" ] || { warn "no such file: $src"; return 1; }
    body="$src"
  fi
  declare -A B16=()
  local k v
  while IFS= read -r line; do
    k="$(sed -nE 's/^[[:space:]]*(base0[0-9A-Fa-f]):[[:space:]]*["'\'']?#?([0-9A-Fa-f]{6}).*/\1/p' <<<"$line")"
    v="$(sed -nE 's/^[[:space:]]*(base0[0-9A-Fa-f]):[[:space:]]*["'\'']?#?([0-9A-Fa-f]{6}).*/\2/p' <<<"$line")"
    [ -n "$k" ] && B16["${k,,}"]="${v,,}"
  done < "$body"
  [ -z "$nm" ] && nm="$(sed -nE 's/^[[:space:]]*(scheme|name):[[:space:]]*["'\'']?([^"'\'']+).*/\2/p' "$body" | head -1)"
  [ -n "$tmp" ] && rm -f "$tmp"
  [ "${#B16[@]}" -lt 16 ] && { warn "not a base16 scheme (found ${#B16[@]}/16 colours)"; return 1; }
  [ -z "$nm" ] && nm="imported"
  local slug; slug="$(echo "$nm" | tr 'A-Z ' 'a-z-' | tr -cd '[:alnum:]._-')"

  # mode from bg lightness
  local gmode=dark L
  read -r _ _ L <<<"$(_hsl "${B16[base00]}")"
  awk -v l="$L" 'BEGIN{exit (l>0.5)?0:1}' && gmode=light

  # accent trio = the 3 most saturated of the 7 accent slots
  local trio; trio="$(for k in base08 base09 base0a base0b base0c base0d base0e; do
      read -r _ S _ <<<"$(_hsl "${B16[$k]}")"; echo "$S ${B16[$k]}"
    done | sort -rn | head -3 | awk '{print $2}')"

  declare -gA GEN=()
  GEN[bg]="${B16[base00]}";      GEN[bg_alt]="${B16[base01]}"
  GEN[bg_dim]="$(_color_op "${B16[base00]}" darker:25)"
  GEN[surface]="${B16[base02]}"; GEN[overlay]="${B16[base03]}"
  GEN[fg]="${B16[base05]}";      GEN[fg_dim]="${B16[base04]}"
  GEN[fg_faint]="${B16[base03]}"
  GEN[accent]="$(sed -n 1p <<<"$trio")"
  GEN[accent2]="$(sed -n 2p <<<"$trio")"
  GEN[accent3]="$(sed -n 3p <<<"$trio")"
  # on_accent: whichever of bg / near-white reads better on the accent
  if awk -v r="$(_contrast "${GEN[bg]}" "${GEN[accent]}")" 'BEGIN{exit (r>=4.5)?0:1}'; then
    GEN[on_accent]="${GEN[bg]}"
  else
    GEN[on_accent]="$([ "$gmode" = dark ] && echo "${B16[base00]}" || echo "${B16[base07]}")"
    awk -v r="$(_contrast "${GEN[on_accent]}" "${GEN[accent]}")" 'BEGIN{exit (r>=3)?0:1}' || GEN[on_accent]=101010
  fi
  GEN[red]="${B16[base08]}";     GEN[green]="${B16[base0b]}"
  GEN[yellow]="${B16[base0a]}";  GEN[blue]="${B16[base0d]}"
  GEN[magenta]="${B16[base0e]}"; GEN[cyan]="${B16[base0c]}"
  GEN[br_black]="${B16[base03]}"; GEN[br_white]="${B16[base07]}"
  local c
  for c in red green yellow blue magenta cyan; do
    GEN[br_$c]="$(_color_op "${GEN[$c]}" lighter:18)"
  done

  say "importing ${BOLD}$nm${NC} → $slug ($gmode, accent #${GEN[accent]})"
  snapshot
  write_generated_theme "$slug" "$nm" "$gmode" >/dev/null
  : > "$OVERRIDES"; echo "$slug" > "$STATE"
  apply_theme "$slug" keep
}

# export the ACTIVE look as a base16 yaml (share your theme anywhere)
export_scheme() {
  load_palette "$(current_theme)" >/dev/null 2>&1
  cat <<EOF
system: "base16"
name: "${THEME_DISPLAY}"
author: "wear (github.com/1ay1/wear)"
variant: "${THEME_MODE}"
palette:
  base00: "#${PAL[bg]}"
  base01: "#${PAL[bg_alt]}"
  base02: "#${PAL[surface]}"
  base03: "#${PAL[br_black]}"
  base04: "#${PAL[fg_dim]}"
  base05: "#${PAL[fg]}"
  base06: "#${PAL[br_white]}"
  base07: "#${PAL[br_white]}"
  base08: "#${PAL[red]}"
  base09: "#${PAL[yellow]}"
  base0A: "#${PAL[yellow]}"
  base0B: "#${PAL[green]}"
  base0C: "#${PAL[cyan]}"
  base0D: "#${PAL[blue]}"
  base0E: "#${PAL[magenta]}"
  base0F: "#${PAL[accent3]}"
EOF
}

# --- main -------------------------------------------------------------------
case "${1:-}" in
  ""|pick|menu)      pick ;;
  list|ls)           list_themes ;;
  current|active)    current_theme ;;
  reload|re)         apply_theme "$(current_theme)" keep ;;
  tweak|edit|ui|t)
    # Prefer the native GTK GUI; fall back to the rofi menu.
    gui="$(command -v wear-gui || echo "$HOME/.local/bin/wear-gui")"
    if [ -x "$gui" ] && python3 -c "import gi; gi.require_version('Adw','1')" >/dev/null 2>&1 \
       && [ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ] && [ "${1:-}" != "--rofi" ]; then
      WEAR_BIN="$SELF" exec "$gui"
    fi
    tweak ;;
  gui)               exec "${WEAR_GUI:-$HOME/.local/bin/wear-gui}" ;;
  set)               # wear set <key> <value...>  (fuzzy keys, smart values)
    shift; key="${1:-}"; shift || true; val="$*"
    [ -z "$key" ] || [ -z "$val" ] && { warn "usage: wear set <key> <value>"; exit 1; }
    smart_set "$key" "$val" ;;
  unset)             # wear unset <key>  (fuzzy)
    shift; [ -z "${1:-}" ] && { warn "usage: wear unset <key>"; exit 1; }
    k="$(_all_keys | _match "$1")" || { warn "unknown property: $1"; exit 1; }
    snapshot; unset_override "$k"; apply_theme "$(current_theme)" keep
    say "$k → back to base ($(eff_value "$k"))" ;;
  reset)             # wipe all live tweaks, back to the pure base theme
    snapshot; : > "$OVERRIDES"; apply_theme "$(current_theme)" keep
    say "tweaks cleared — back to pure $(pretty_name "$(current_theme)")" ;;
  save)              shift; save_theme "${1:-}" ;;
  random|random-accents|shuffle) # wear random [accents|shape|feel|bar|popups|everything]
    sect="${2:-}"
    [ "$1" = random-accents ] && sect="${sect:-accents}"
    sect="$(printf '%s\n' accents colours shape feel bar popups everything all | _match "${sect:-everything}" || echo everything)"
    snapshot
    case "$sect" in
      accents|colours) randomise_accents; msg="colours: ${RANDOM_STRATEGY:-}" ;;
      shape)   randomise_shape;   msg="shape (radius/borders/gaps)" ;;
      feel)    randomise_feel;    msg="feel (opacity/blur/glow/anims)" ;;
      bar)     randomise_bar;     msg="bar (geometry & look)" ;;
      popups)  randomise_popups;  msg="popups (launcher & notifications)" ;;
      *)       randomise_accents; randomise_shape; randomise_feel; randomise_bar; randomise_popups
               msg="everything — ${RANDOM_STRATEGY:-} accents + shape + feel + bar + popups" ;;
    esac
    apply_theme "$(current_theme)" keep
    say "randomised ${BOLD}$msg${NC} — roll again, or wear undo" ;;
  from-color|color)  shift; from_color "$@" ;;
  from|from-image)   shift; from_image "$@" ;;
  dark|light)        flip_mode "$1" ;;
  toggle|flip)       flip_mode toggle ;;
  doctor|check|audit) shift || true; doctor "${1:-}" ;;
  import)            shift; import_scheme "$@" ;;
  export)            export_scheme ;;
  update|upgrade)    # pull the latest wear + re-deploy, keeping your look
    if [ ! -d "$REPO/.git" ]; then warn "$REPO is not a git clone — can't self-update"; exit 1; fi
    say "updating ${BOLD}wear${NC} in $REPO"
    git -C "$REPO" pull --ff-only || { warn "git pull failed (local changes in $REPO?)"; exit 1; }
    PHOSPHOR_SKIP_PKGS=1 bash "$REPO/install.sh" --skip-pkgs ;;
  undo)              undo ;;
  show|preview)      show_palette ;;
  tweaks|diff)       # show the active overrides
    if [ -s "$OVERRIDES" ]; then cat "$OVERRIDES"; else echo "(no tweaks — pure $(current_theme))"; fi ;;
  schema)            tweak_schema ;;   # machine-readable prop schema (for the GUI)
  options)           shift; list_options "${1:-}" ;;  # discovered choices for pick: keys
  get)               shift; eff_value "${1:-}"; echo ;;   # effective value of one key
  values)            # dump every schema key's effective value as key=value
    load_palette "$(current_theme)" >/dev/null 2>&1
    while IFS='|' read -r k _ _ _; do
      case "$k" in '##'*|'') continue ;; esac
      printf '%s=%s\n' "$k" "${PAL[$k]:-}"
    done < <(tweak_schema) ;;
  is-overridden)     shift; grep -qE "^\s*${1:-__none__}=" "$OVERRIDES" 2>/dev/null && echo yes || echo no ;;
  -h|--help|help)
    sed -n '2,20p' "$SELF" | sed 's/^# \{0,1\}//'
    echo
    echo "Tweaker:"
    echo "  wear tweak            live appearance editor (GTK GUI, Super+A)"
    echo "  wear set <k> <v>      smart set — fuzzy keys, named colours, relative"
    echo "                        values: wear set radius +4 · accent lighter · gaps 2x"
    echo "  wear unset <k>        drop one tweak (fuzzy)   · wear set <k> default"
    echo "  wear tweaks           show active tweaks"
    echo "  wear reset            clear all tweaks"
    echo "  wear undo             revert the last change (30 steps)"
    echo "  wear save <name>      snapshot current look as a new theme"
    echo "  wear random [what]    tasteful dice roll — everything (default),"
    echo "                        or just: accents shape feel bar popups"
    echo
    echo "Smart:"
    echo "  wear dark|light|toggle  flip ANY theme's polarity, hues preserved"
    echo "  wear doctor [--fix]     WCAG contrast audit — --fix repairs live"
    echo "  wear import <yml|url>   wear any base16 scheme (~250 exist)"
    echo "  wear export             active look as base16 yaml (share it)"
    echo
    echo "Generators:"
    echo "  wear from <image>     full theme from a wallpaper/photo"
    echo "  wear from-color <c>   full theme from one colour (hex or name; --light)"
    echo "  wear show             truecolor palette swatches in the terminal"
    echo
    echo "  wear update           pull the latest wear + re-deploy (look kept)" ;;
  *)
    if [ -f "$THEMES_DIR/$1.theme" ]; then snapshot; apply_theme "$1"
    elif t="$(list_themes | _match "$1")" && [ -n "$t" ]; then
      info "$1 → ${BOLD}$t${NC}"; snapshot; apply_theme "$t"
    elif cmd="$(printf '%s\n' list current reload tweak set unset reset undo save random-accents from from-color dark light toggle doctor import export update show tweaks schema options get values help | _match "$1")" && [ -n "$cmd" ]; then
      warn "no such theme or command: $1 — did you mean ${BOLD}wear $cmd${NC}?"; exit 1
    else
      warn "no such theme: $1"; echo; echo "Available:"; list_themes; exit 1
    fi ;;
esac
