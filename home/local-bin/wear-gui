#!/usr/bin/env python3
"""wear-gui — native GTK4/Adwaita appearance tweaker for the Phosphor desktop.

A friendly front-end over the `wear` CLI. It reads the property schema and the
effective palette from `wear`, shows grouped sliders / colour buttons / dropdowns
/ font pickers, and on every change runs `wear set <key> <value>` — which
re-renders and reloads the whole desktop live.

No theming logic lives here; `wear` remains the single source of truth.
"""
from __future__ import annotations
import os
import shutil
import subprocess
import sys

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, Gio, Gdk, GLib, Pango  # noqa: E402

WEAR = os.environ.get("WEAR_BIN") or shutil.which("wear") \
    or os.path.expanduser("~/.local/bin/wear")

CATEGORY_ICONS = {
    "Colours": "applications-graphics-symbolic",
    "Shape": "view-grid-symbolic",
    "Feel": "weather-clear-symbolic",
    "Bar": "view-dual-symbolic",
    "Popups": "user-available-symbolic",
    "Type": "font-x-generic-symbolic",
    "System": "applications-system-symbolic",
}

# Inside the single Colours page, split rows into titled groups for scanning.
ANSI_KEYS = {"red", "green", "yellow", "blue", "magenta", "cyan",
             "br_black", "br_red", "br_green", "br_yellow", "br_blue",
             "br_magenta", "br_cyan", "br_white"}


def wear(*args: str, capture: bool = True) -> str:
    """Run the wear CLI; return stdout (stripped) when capture=True."""
    try:
        r = subprocess.run([WEAR, *args], capture_output=capture, text=True)
        return (r.stdout or "").strip() if capture else ""
    except Exception as e:  # noqa: BLE001
        sys.stderr.write(f"wear {' '.join(args)} failed: {e}\n")
        return ""


def load_schema() -> list[tuple[str, list[dict]]]:
    """Return [(category, [prop, ...]), ...] parsed from `wear schema`."""
    cats: list[tuple[str, list[dict]]] = []
    cur: list[dict] | None = None
    for line in wear("schema").splitlines():
        line = line.rstrip("\n")
        if line.startswith("## "):
            cur = []
            cats.append((line[3:].strip(), cur))
            continue
        if not line or cur is None:
            continue
        parts = line.split("|")
        if len(parts) < 3:
            continue
        key, label, typ = parts[0], parts[1], parts[2]
        spec = parts[3] if len(parts) > 3 else ""
        cur.append({"key": key, "label": label, "type": typ, "spec": spec})
    return cats


def load_values() -> dict[str, str]:
    vals: dict[str, str] = {}
    for line in wear("values").splitlines():
        if "=" in line:
            k, v = line.split("=", 1)
            vals[k.strip()] = v.strip()
    return vals


def hex_to_rgba(h: str) -> Gdk.RGBA:
    rgba = Gdk.RGBA()
    rgba.parse("#" + h.lstrip("#"))
    return rgba


def rgba_to_hex(rgba: Gdk.RGBA) -> str:
    return "%02x%02x%02x" % (
        round(rgba.red * 255), round(rgba.green * 255), round(rgba.blue * 255)
    )


def _rgb(h: str):
    """'aabbcc' -> (r,g,b) floats in 0..1 for Cairo."""
    h = (h or "000000").lstrip("#")
    if len(h) != 6:
        h = "000000"
    return (int(h[0:2], 16) / 255, int(h[2:4], 16) / 255, int(h[4:6], 16) / 255)


class PreviewStrip(Gtk.DrawingArea):
    """A live 'mini desktop' painted with Cairo from the current palette: a
    wallpaper field, a title-barred window with sample text, the accent trio as
    chips, and the ANSI row. It repaints instantly on every tweak (no desktop
    round-trip) so you SEE a colour/opacity/radius change before the real
    desktop even reloads. Call set_palette(values) to update."""

    def __init__(self):
        super().__init__()
        self.vals: dict[str, str] = {}
        self.set_content_height(96)
        self.set_draw_func(self._draw)

    def set_palette(self, vals: dict[str, str]):
        self.vals = vals or {}
        self.queue_draw()

    def _draw(self, _area, cr, w, h, *_):
        v = self.vals
        def col(k, fb="000000"):
            return _rgb(v.get(k) or fb)
        try:
            radius = float(v.get("radius", 8) or 8)
        except ValueError:
            radius = 8.0
        try:
            opac = float(v.get("opacity_active", 1.0) or 1.0)
        except ValueError:
            opac = 1.0
        # wallpaper: bg_dim wash
        cr.set_source_rgb(*col("bg_dim", v.get("bg", "101010")))
        cr.rectangle(0, 0, w, h)
        cr.fill()
        # the bar strip across the top, in bg_alt with an accent left cap
        bar_h = 16
        cr.set_source_rgb(*col("bg_alt", v.get("bg", "101010")))
        cr.rectangle(0, 0, w, bar_h)
        cr.fill()
        cr.set_source_rgb(*col("accent"))
        cr.rectangle(8, 4, 26, bar_h - 8)
        cr.fill()
        # a couple of bar module ticks in fg_dim
        cr.set_source_rgb(*col("fg_dim", v.get("fg", "cccccc")))
        for i in range(3):
            cr.rectangle(w - 84 + i * 26, 6, 18, 4)
            cr.fill()
        # a window: rounded rect in bg (honouring opacity), border in accent
        wx, wy, ww, wh = 22, bar_h + 12, w - 44, h - bar_h - 24
        rr = max(0.0, min(radius, wh / 2, 22))
        self._rounded(cr, wx, wy, ww, wh, rr)
        br, bg, bb = col("bg")
        cr.set_source_rgba(br, bg, bb, opac)
        cr.fill_preserve()
        cr.set_source_rgb(*col("accent"))
        cr.set_line_width(1.5)
        cr.stroke()
        # title bar inside the window
        self._rounded(cr, wx, wy, ww, 14, rr, top_only=True)
        cr.set_source_rgb(*col("surface", v.get("bg_alt", "181818")))
        cr.fill()
        # sample text lines (fg / fg_dim)
        cr.set_source_rgb(*col("fg"))
        cr.rectangle(wx + 10, wy + 22, ww * 0.5, 4); cr.fill()
        cr.set_source_rgb(*col("fg_dim", v.get("fg", "cccccc")))
        cr.rectangle(wx + 10, wy + 30, ww * 0.36, 3); cr.fill()
        cr.rectangle(wx + 10, wy + 37, ww * 0.42, 3); cr.fill()
        # accent trio chips
        for i, k in enumerate(("accent", "accent2", "accent3")):
            cr.set_source_rgb(*col(k))
            cx = wx + 10 + i * 16
            cr.arc(cx + 5, wy + wh - 12, 5, 0, 6.2832)
            cr.fill()
        # ANSI swatch row along the bottom-right of the window
        ansi = ("red", "green", "yellow", "blue", "magenta", "cyan")
        sw = 9
        x0 = wx + ww - (len(ansi) * (sw + 2)) - 8
        for i, k in enumerate(ansi):
            cr.set_source_rgb(*col(k))
            cr.rectangle(x0 + i * (sw + 2), wy + wh - 16, sw, 8)
            cr.fill()

    @staticmethod
    def _rounded(cr, x, y, w, h, r, top_only=False):
        import math
        cr.new_sub_path()
        cr.arc(x + w - r, y + r, r, -math.pi / 2, 0)
        if top_only:
            cr.line_to(x + w, y + h)
            cr.line_to(x, y + h)
        else:
            cr.arc(x + w - r, y + h - r, r, 0, math.pi / 2)
            cr.arc(x + r, y + h - r, r, math.pi / 2, math.pi)
        cr.arc(x + r, y + r, r, math.pi, 3 * math.pi / 2)
        cr.close_path()


class WearWindow(Adw.ApplicationWindow):
    def __init__(self, app: "WearApp"):
        super().__init__(application=app, title="Appearance")
        self.set_default_size(920, 680)
        self._apply_pending = False
        self._debounce_id = 0
        self._pending_args: tuple[str, str] | None = None
        self._building = False   # suppress widget callbacks during (re)build

        self.schema = load_schema()
        self.values = load_values()

        # ---- layout: split view, sidebar + content -------------------------
        split = Adw.NavigationSplitView()
        self.set_content(split)

        # sidebar
        sb_page = Adw.NavigationPage(title="wear")
        sb_tb = Adw.ToolbarView()
        sb_header = Adw.HeaderBar()
        sb_header.set_title_widget(Adw.WindowTitle(title="wear", subtitle="appearance"))
        sb_tb.add_top_bar(sb_header)
        self.sidebar = Gtk.ListBox()
        self.sidebar.set_css_classes(["navigation-sidebar"])
        self.sidebar.connect("row-selected", self._on_category_selected)
        sb_scroll = Gtk.ScrolledWindow(child=self.sidebar, vexpand=True)
        sb_tb.set_content(sb_scroll)
        sb_page.set_child(sb_tb)
        split.set_sidebar(sb_page)

        # content
        self.content_page = Adw.NavigationPage(title="Colours")
        content_tb = Adw.ToolbarView()
        header = Adw.HeaderBar()
        content_tb.add_top_bar(header)

        # header buttons: base theme, random, save, reset
        theme_btn = Gtk.Button(icon_name="view-list-symbolic", tooltip_text="Switch base theme")
        theme_btn.connect("clicked", self._on_pick_theme)
        header.pack_start(theme_btn)

        rnd_btn = Gtk.Button(icon_name="media-playlist-shuffle-symbolic",
                             tooltip_text="Randomise everything (style only)")
        rnd_btn.connect("clicked", lambda *_: self._run_and_refresh("random", "everything"))
        header.pack_start(rnd_btn)

        undo_btn = Gtk.Button(icon_name="edit-undo-symbolic", tooltip_text="Undo last change")
        undo_btn.connect("clicked", lambda *_: self._run_and_refresh("undo"))
        header.pack_start(undo_btn)

        mode_btn = Gtk.Button(icon_name="weather-clear-night-symbolic",
                              tooltip_text="Flip dark ↔ light (hues preserved)")
        mode_btn.connect("clicked", lambda *_: self._run_and_refresh("toggle"))
        header.pack_start(mode_btn)

        menu = Gio.Menu()
        menu.append("Theme from wallpaper…", "win.from-image")
        menu.append("Theme from a colour…", "win.from-color")
        menu.append("Import base16 scheme…", "win.import")
        menu.append("Export as base16…", "win.export")
        menu.append("Check contrast (doctor)", "win.doctor")
        menu.append("Save as new theme…", "win.save")
        menu.append("Reset all tweaks", "win.reset")
        menu_btn = Gtk.MenuButton(icon_name="open-menu-symbolic", menu_model=menu)
        header.pack_end(menu_btn)
        self._install_actions()

        self.title_widget = Adw.WindowTitle(title="Colours", subtitle=self._subtitle())
        header.set_title_widget(self.title_widget)

        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        content_tb.set_content(self.stack)

        # live preview strip pinned to the bottom — a Cairo mini-desktop that
        # repaints from the palette on every tweak, so the effect is visible
        # instantly even before the real desktop finishes reloading.
        self.preview = PreviewStrip()
        preview_bar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        preview_bar.append(Gtk.Separator())
        pv_label = Gtk.Label(label="live preview", xalign=0,
                             css_classes=["dim-label", "caption"],
                             margin_start=12, margin_top=4)
        preview_bar.append(pv_label)
        preview_bar.append(self.preview)
        content_tb.add_bottom_bar(preview_bar)
        self.preview.set_palette(self.values)

        self.content_page.set_child(content_tb)
        split.set_content(self.content_page)

        self._build_pages()

    # -- helpers -------------------------------------------------------------
    def _subtitle(self) -> str:
        base = wear("current") or "?"
        n = 0
        tw = wear("tweaks")
        if tw and not tw.startswith("("):
            n = len([l for l in tw.splitlines() if l.strip()])
        return f"{base} · {n} tweak{'s' if n != 1 else ''}"

    def _refresh_subtitle(self):
        self.title_widget.set_subtitle(self._subtitle())

    def _set(self, key: str, value: str):
        """Debounced live apply so dragging a slider doesn't spam reloads."""
        if self._building:
            return  # ignore events fired while constructing widgets
        # update the in-memory palette + repaint the preview IMMEDIATELY, so the
        # strip reflects the change before the (debounced) desktop reload lands.
        self.values[key] = value
        self.preview.set_palette(self.values)
        self._pending_args = (key, value)
        if self._debounce_id:
            GLib.source_remove(self._debounce_id)
        self._debounce_id = GLib.timeout_add(140, self._flush_set)

    def _flush_set(self) -> bool:
        self._debounce_id = 0
        if self._pending_args:
            k, v = self._pending_args
            self._pending_args = None
            subprocess.Popen([WEAR, "set", k, v],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            GLib.timeout_add(200, self._refresh_subtitle_cb)
        return False

    def _refresh_subtitle_cb(self) -> bool:
        # pull the authoritative post-apply palette (values may have been clamped
        # or a colour op resolved) and repaint the strip from truth.
        self.values = load_values()
        self.preview.set_palette(self.values)
        self._refresh_subtitle()
        return False

    def _run_and_refresh(self, *args: str):
        wear(*args)
        self.values = load_values()
        self.preview.set_palette(self.values)
        self._build_pages()
        self._refresh_subtitle()

    # -- category navigation -------------------------------------------------
    def _on_category_selected(self, _box, row):
        if row is None:
            return
        name = row.get_child().get_label() if isinstance(row.get_child(), Gtk.Label) else row._cat
        self.stack.set_visible_child_name(name)
        self.title_widget.set_title(name)
        self.content_page.set_title(name)

    # -- build all pages -----------------------------------------------------
    # Pages that have a style randomiser in the engine (wear random <section>).
    RANDOM_SECTIONS = {"Colours": "colours", "Shape": "shape", "Feel": "feel",
                       "Bar": "bar", "Popups": "popups"}

    def _rand_btn(self, sect: str) -> Gtk.Button:
        btn = Gtk.Button(icon_name="media-playlist-shuffle-symbolic",
                         valign=Gtk.Align.CENTER, css_classes=["flat"],
                         tooltip_text=f"Randomise {sect} (tasteful ranges — undo to revert)")
        btn.connect("clicked", lambda *_: self._run_and_refresh("random", sect))
        return btn

    def _build_pages(self):
        self._building = True
        # remember which page the user is on so a rebuild (randomise/undo/...)
        # restores it instead of dumping them back on the first page
        prev_cat = self.stack.get_visible_child_name()
        # clear old
        child = self.sidebar.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self.sidebar.remove(child)
            child = nxt
        old = self.stack.get_first_child()
        while old:
            nxt = old.get_next_sibling()
            self.stack.remove(old)
            old = nxt

        first_row = None
        restore_row = None
        for cat, props in self.schema:
            # sidebar row
            row = Gtk.ListBoxRow()
            row._cat = cat
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12,
                          margin_top=10, margin_bottom=10, margin_start=8, margin_end=8)
            icon = Gtk.Image.new_from_icon_name(
                CATEGORY_ICONS.get(cat, "preferences-system-symbolic"))
            box.append(icon)
            box.append(Gtk.Label(label=cat, xalign=0))
            row.set_child(box)
            self.sidebar.append(row)
            if first_row is None:
                first_row = row
            if cat == prev_cat:
                restore_row = row

            # content page
            page = Adw.PreferencesPage()
            rand_sect = self.RANDOM_SECTIONS.get(cat)
            if cat == "Colours":
                # one section, but grouped for scanability
                ui_grp = Adw.PreferencesGroup(
                    title="Palette",
                    description="Every colour below drives GTK, Qt, KDE, the bar, "
                                "terminal, notifications and window borders at once.")
                if rand_sect:
                    ui_grp.set_header_suffix(self._rand_btn(rand_sect))
                term_grp = Adw.PreferencesGroup(title="Terminal ANSI (also used as semantic colours)")
                page.add(ui_grp)
                page.add(term_grp)
                for p in props:
                    (term_grp if p["key"] in ANSI_KEYS else ui_grp).add(self._build_row(p))
            elif cat == "Bar":
                look_grp = Adw.PreferencesGroup(
                    title="Geometry &amp; look",
                    description="Changes restart waybar instantly.")
                if rand_sect:
                    look_grp.set_header_suffix(self._rand_btn(rand_sect))
                mod_grp = Adw.PreferencesGroup(title="Modules")
                page.add(look_grp)
                page.add(mod_grp)
                for p in props:
                    (mod_grp if p["key"].startswith("bar_mod_") else look_grp).add(self._build_row(p))
            else:
                grp = Adw.PreferencesGroup(title=cat)
                if rand_sect:
                    grp.set_header_suffix(self._rand_btn(rand_sect))
                page.add(grp)
                for p in props:
                    grp.add(self._build_row(p))
            scroller = Gtk.ScrolledWindow(child=page, vexpand=True)
            self.stack.add_named(scroller, cat)

        if restore_row is not None:
            self.sidebar.select_row(restore_row)
        elif first_row:
            self.sidebar.select_row(first_row)
        # let queued construction events drain before re-enabling applies
        GLib.idle_add(self._end_building)

    def _end_building(self) -> bool:
        self._building = False
        return False

    # -- one preference row per property ------------------------------------
    def _build_row(self, p: dict) -> Gtk.Widget:
        key, label, typ, spec = p["key"], p["label"], p["type"], p["spec"]
        val = self.values.get(key, "")

        if typ == "color":
            row = Adw.ActionRow(title=label, subtitle=("#" + val) if val else spec)
            btn = Gtk.ColorButton(valign=Gtk.Align.CENTER)
            btn.set_use_alpha(False)
            if val:
                btn.set_rgba(hex_to_rgba(val))
            btn.connect("color-set", self._on_color, key, row)
            row.add_suffix(btn)
            row.set_activatable_widget(btn)
            return row

        if typ.startswith("int:") or typ.startswith("float:"):
            _, mn, mx, st = typ.split(":")
            is_float = typ.startswith("float:")
            row = Adw.ActionRow(title=label, subtitle=spec)
            adj = Gtk.Adjustment(lower=float(mn), upper=float(mx),
                                 step_increment=float(st), page_increment=float(st))
            try:
                adj.set_value(float(val))
            except (TypeError, ValueError):
                adj.set_value(float(mn))
            scale = Gtk.Scale(adjustment=adj, hexpand=True, draw_value=True,
                              digits=(2 if is_float else 0), valign=Gtk.Align.CENTER)
            scale.set_size_request(260, -1)
            scale.set_value_pos(Gtk.PositionType.RIGHT)
            scale.connect("value-changed", self._on_scale, key, is_float)
            row.add_suffix(scale)
            return row

        if typ == "choice":
            opts = [o for o in spec.split(",") if o]
            if opts == ["on", "off"] or opts == ["off", "on"]:
                row = Adw.SwitchRow(title=label, active=(val == "on"))
                row.connect("notify::active", self._on_switch, key)
                return row
            row = Adw.ComboRow(title=label, subtitle=spec)
            model = Gtk.StringList.new(opts)
            row.set_model(model)
            if val in opts:
                row.set_selected(opts.index(val))
            row.connect("notify::selected", self._on_choice, key, opts)
            return row

        if typ.startswith("pick:"):
            kind = typ.split(":", 1)[1]
            opts = [o for o in wear("options", kind).splitlines() if o.strip()]
            row = Adw.ComboRow(title=label, subtitle=spec)
            if not opts:
                row.set_subtitle(f"nothing found for {kind} on this system")
                row.set_sensitive(False)
                return row
            if val and val not in opts:
                opts.insert(0, val)          # keep the current value selectable
            model = Gtk.StringList.new(opts)
            row.set_model(model)
            # searchable: type to filter long lists (icon/gtk/kvantum/shaders)
            row.set_enable_search(True)
            row.set_expression(Gtk.PropertyExpression.new(Gtk.StringObject, None, "string"))
            if val in opts:
                row.set_selected(opts.index(val))
            row.connect("notify::selected", self._on_choice, key, opts)
            return row

        if typ == "font":
            row = Adw.ActionRow(title=label, subtitle=val or spec)
            btn = Gtk.FontButton(valign=Gtk.Align.CENTER)
            btn.set_use_size(False)
            if val:
                btn.set_font(val + " 12")
            btn.connect("font-set", self._on_font, key, row)
            row.add_suffix(btn)
            row.set_activatable_widget(btn)
            return row

        return Adw.ActionRow(title=label, subtitle=val)

    # -- widget callbacks ----------------------------------------------------
    def _on_color(self, btn, key, row):
        h = rgba_to_hex(btn.get_rgba())
        row.set_subtitle("#" + h)
        self._set(key, h)

    def _on_scale(self, scale, key, is_float):
        v = scale.get_value()
        self._set(key, ("%.2f" % v) if is_float else str(int(round(v))))

    def _on_choice(self, row, _pspec, key, opts):
        idx = row.get_selected()
        if 0 <= idx < len(opts):
            self._set(key, opts[idx])

    def _on_switch(self, row, _pspec, key):
        self._set(key, "on" if row.get_active() else "off")

    def _on_font(self, btn, key, row):
        desc = btn.get_font_desc()
        fam = desc.get_family() if desc else btn.get_font()
        if fam:
            row.set_subtitle(fam)
            self._set(key, fam)

    # -- header actions ------------------------------------------------------
    def _install_actions(self):
        for name, cb in (("save", self._on_save), ("reset", self._on_reset),
                         ("from-image", self._on_from_image),
                         ("from-color", self._on_from_color),
                         ("import", self._on_import),
                         ("export", self._on_export),
                         ("doctor", self._on_doctor)):
            act = Gio.SimpleAction.new(name, None)
            act.connect("activate", cb)
            self.add_action(act)

    def _on_reset(self, *_):
        dlg = Adw.MessageDialog(transient_for=self, heading="Reset all tweaks?",
                                body="Return to the pure base theme. This can't be undone.")
        dlg.add_response("cancel", "Cancel")
        dlg.add_response("reset", "Reset")
        dlg.set_response_appearance("reset", Adw.ResponseAppearance.DESTRUCTIVE)
        dlg.connect("response", lambda d, r: r == "reset" and self._run_and_refresh("reset"))
        dlg.present()

    def _on_save(self, *_):
        dlg = Adw.MessageDialog(transient_for=self, heading="Save as new theme",
                                body="Bake the current look into a reusable theme.")
        entry = Gtk.Entry(placeholder_text="my-theme")
        dlg.set_extra_child(entry)
        dlg.add_response("cancel", "Cancel")
        dlg.add_response("save", "Save")
        dlg.set_response_appearance("save", Adw.ResponseAppearance.SUGGESTED)
        dlg.set_default_response("save")

        def _resp(d, r):
            name = entry.get_text().strip()
            if r == "save" and name:
                self._run_and_refresh("save", name)
        dlg.connect("response", _resp)
        dlg.present()

    def _on_pick_theme(self, *_):
        themes = wear("list").split()
        cur = wear("current")
        dlg = Adw.MessageDialog(transient_for=self, heading="Base theme",
                                body="Switching clears live tweaks.")
        listbox = Gtk.ListBox(css_classes=["boxed-list"])
        for t in themes:
            r = Adw.ActionRow(title=t)
            if t == cur:
                r.add_suffix(Gtk.Image.new_from_icon_name("emblem-ok-symbolic"))
            r._t = t
            listbox.append(r)
        listbox.connect("row-activated",
                        lambda _b, row: (self._run_and_refresh(row._t), dlg.close()))
        dlg.set_extra_child(listbox)
        dlg.add_response("close", "Close")
        dlg.present()

    def _on_from_image(self, *_):
        """Generate a whole theme from an image the user picks."""
        dlg = Gtk.FileDialog(title="Theme from image")
        f = Gtk.FileFilter()
        f.set_name("Images")
        for pat in ("*.png", "*.jpg", "*.jpeg", "*.webp", "*.bmp"):
            f.add_pattern(pat)
        filters = Gio.ListStore.new(Gtk.FileFilter)
        filters.append(f)
        dlg.set_filters(filters)

        def _done(d, res):
            try:
                gfile = d.open_finish(res)
            except GLib.Error:
                return
            path = gfile.get_path()
            if path:
                self._run_and_refresh("from", path)
        dlg.open(self, None, _done)

    def _on_from_color(self, *_):
        """Generate a whole theme from a single seed colour."""
        cdlg = Gtk.ColorDialog(title="Seed colour", with_alpha=False)

        def _done(d, res):
            try:
                rgba = d.choose_rgba_finish(res)
            except GLib.Error:
                return
            if rgba:
                self._run_and_refresh("from-color", rgba_to_hex(rgba))
        cdlg.choose_rgba(self, hex_to_rgba(self.values.get("accent", "3366cc")),
                         None, _done)

    def _on_import(self, *_):
        """Import a base16 scheme from a yaml file."""
        dlg = Gtk.FileDialog(title="Import base16 scheme")
        f = Gtk.FileFilter()
        f.set_name("base16 schemes")
        for pat in ("*.yaml", "*.yml"):
            f.add_pattern(pat)
        filters = Gio.ListStore.new(Gtk.FileFilter)
        filters.append(f)
        dlg.set_filters(filters)

        def _done(d, res):
            try:
                gfile = d.open_finish(res)
            except GLib.Error:
                return
            path = gfile.get_path()
            if path:
                self._run_and_refresh("import", path)
        dlg.open(self, None, _done)

    def _on_export(self, *_):
        """Save the active look as a base16 yaml."""
        dlg = Gtk.FileDialog(title="Export as base16",
                             initial_name=f"{wear('current') or 'theme'}.yaml")

        def _done(d, res):
            try:
                gfile = d.save_finish(res)
            except GLib.Error:
                return
            path = gfile.get_path()
            if path:
                with open(path, "w") as fh:
                    fh.write(wear("export") + "\n")
        dlg.save(self, None, _done)

    def _on_doctor(self, *_):
        """Run the WCAG contrast audit; offer auto-fix when checks fail."""
        r = subprocess.run([WEAR, "doctor"], capture_output=True, text=True)
        import re
        plain = re.sub(r"\x1b\[[0-9;]*m", "", (r.stdout or "") + (r.stderr or ""))
        ok = r.returncode == 0
        dlg = Adw.MessageDialog(
            transient_for=self,
            heading="All contrast checks pass" if ok else "Contrast issues found",
            body="")
        view = Gtk.Label(label=plain.strip(), css_classes=["monospace"],
                         xalign=0, wrap=False, selectable=True)
        scroll = Gtk.ScrolledWindow(child=view, min_content_height=280,
                                    min_content_width=560)
        dlg.set_extra_child(scroll)
        dlg.add_response("close", "Close")
        if not ok:
            dlg.add_response("fix", "Fix automatically")
            dlg.set_response_appearance("fix", Adw.ResponseAppearance.SUGGESTED)
            dlg.connect("response",
                        lambda d, resp: resp == "fix" and self._run_and_refresh("doctor", "--fix"))
        dlg.present()


class WearApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="dev.phosphor.wear",
                         flags=Gio.ApplicationFlags.DEFAULT_FLAGS)

    def do_activate(self):
        win = self.props.active_window or WearWindow(self)
        win.present()


def main() -> int:
    app = WearApp()
    return app.run(None)


if __name__ == "__main__":
    raise SystemExit(main())
